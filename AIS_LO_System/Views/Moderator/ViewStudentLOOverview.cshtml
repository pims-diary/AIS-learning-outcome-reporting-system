@model AIS_LO_System.Models.Reports.StudentCourseLOOverviewViewModel
@using AIS_LO_System.Models
@{
    ViewData["Title"] = "Review: Student LO Overview";
    Layout = "_DashboardLayout";
    var submission = ViewBag.Submission as CourseSubmission;
    int submissionId = ViewBag.SubmissionId;
}

<link rel="stylesheet" href="~/css/moderator.css" />

<div class="container mt-4">
    <div class="mod-doc-header">
        <a asp-action="ViewStudentLOReport" asp-route-submissionId="@submissionId" class="mod-back">← Back to Student List</a>
        <h1>Student LO Overview — @Model.CourseCode @Model.Year T@(Model.Trimester)</h1>
    </div>

    @await Component.InvokeAsync("SubmissionStatus", new { submission })

    <div class="d-flex justify-content-between align-items-start mt-4 mb-4">
        <div>
            <h2 class="fw-bold mb-1">@Model.StudentName</h2>
            <div class="text-muted mb-1"><strong>Student ID:</strong> @Model.StudentId</div>
            <div class="text-muted mb-1"><strong>Course:</strong> @Model.CourseCode @Model.CourseTitle</div>
            <div class="text-muted"><strong>Semester:</strong> @Model.TrimesterLabel</div>
        </div>
    </div>

    <!-- Bar graph -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Overall LO Achievement Overview</h4>
            @if (Model.LOSummaries.Any())
            {
                <div class="chart-box">
                    <div class="y-axis-label top">100</div>
                    <div class="chart-grid">
                        <div class="grid-line line-80"></div>
                        <div class="grid-line line-60"></div>
                        <div class="grid-line line-40"></div>
                        <div class="grid-line line-20"></div>
                        <div class="bars-wrap">
                            @foreach (var lo in Model.LOSummaries)
                            {
                                <div class="bar-item">
                                    <div class="bar-percent">@lo.Percentage.ToString("0.##")%</div>
                                    <div class="bar @(lo.Status == "Achieved" ? "bar-achieved" : "bar-not-achieved")" style="height:@lo.Percentage%;"></div>
                                    <div class="bar-label">@lo.Label</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="chart-info-box">
                    <div class="chart-info-status">@Model.AchievedCount of @Model.TotalLOCount Learning Outcomes Achieved</div>
                    <div class="legend-inline">
                        <div class="legend-item"><span class="legend-box achieved-box"></span> Achieved</div>
                        <div class="legend-item"><span class="legend-box not-box"></span> Not Achieved</div>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No graded assessment data is available yet for this student.</p>
            }
        </div>
    </div>

    <!-- Analysis -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Learning Outcome Analysis</h4>
            @if (!Model.LOAnalyses.Any())
            {
                <p class="text-muted mb-0">No LO analysis available yet — no assessments have been graded.</p>
            }
            else
            {
                @foreach (var item in Model.LOAnalyses)
                {
                    <div class="analysis-block">
                        <div class="analysis-title">@item.Label - @item.Percentage.ToString("0.##")% (@item.Status)</div>
                        <div class="analysis-text mb-2"><strong>@item.Label</strong>: @item.LearningOutcomeText</div>
                        @foreach (var line in item.AssessmentBreakdown)
                        {
                            <div class="analysis-text">@line</div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- Contribution Table -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Assessment Contribution to Course Learning Outcomes</h4>
            @if (!Model.Contributions.Any())
            {
                <p class="text-muted mb-0">No contribution data available yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>Assessment</th>
                                <th>Status</th>
                                <th>Total Contribution to LO(s)</th>
                                <th>Student Achievement</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Contributions)
                            {
                                <tr>
                                    <td>@item.AssessmentName</td>
                                    <td>
                                        <span class="badge @(item.IsGraded ? "bg-success" : "bg-secondary")">@item.StatusText</span>
                                    </td>
                                    <td>@foreach (var c in item.Contributions) { <div>@c</div> }</td>
                                    <td>@foreach (var a in item.Achievements) { <div>@a</div> }</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Combined LO Summary -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Combined LO Summary</h4>
            @if (Model.LOSummaries.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>LO</th>
                                <th>Learning Outcome</th>
                                <th>Student Score</th>
                                <th>Max Possible Score</th>
                                <th>Achievement (%)</th>
                                <th>LO Result</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lo in Model.LOSummaries)
                            {
                                <tr>
                                    <td>@lo.Label</td>
                                    <td>@lo.LearningOutcomeText</td>
                                    <td>@lo.AchievedScore.ToString("0.00")</td>
                                    <td>@lo.MaxScore.ToString("0.00")</td>
                                    <td>@lo.Percentage.ToString("0.##")%</td>
                                    <td>
                                        <span class="badge @(lo.Status == "Achieved" ? "bg-success" : "bg-danger")">@lo.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No graded assessment data available yet.</p>
            }
        </div>
    </div>
</div>

<style>
    .chart-box { position: relative; padding-left: 34px; padding-top: 18px; }
    .y-axis-label.top { position: absolute; left: 0; top: 0; font-size: 0.95rem; color: #c62828; font-weight: 700; }
    .chart-grid { position: relative; height: 340px; border-left: 2px solid #555; border-bottom: 2px solid #555; margin-top: 10px; }
    .grid-line { position: absolute; left: 0; right: 0; border-top: 1px solid #bbb; }
    .line-80 { top: 20%; } .line-60 { top: 40%; } .line-40 { top: 60%; } .line-20 { top: 80%; }
    .bars-wrap { position: absolute; left: 30px; right: 30px; bottom: 0; top: 0; display: flex; justify-content: space-around; align-items: flex-end; padding-bottom: 36px; }
    .bar-item { width: 90px; height: 100%; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; }
    .bar { width: 40px; min-height: 2px; border: 1px solid #555; }
    .bar-percent { font-size: 1rem; color: #c62828; font-weight: 700; margin-bottom: 8px; }
    .bar-label { margin-top: 8px; font-size: 0.95rem; color: #c62828; font-weight: 600; }
    .bar-achieved { background: green; } .bar-not-achieved { background: red; }
    .chart-info-box { margin-top: 16px; padding: 12px 14px; background: #fafafa; border: 1px solid #e1e1e1; border-radius: 6px; }
    .chart-info-status { font-weight: 700; color: #b32017; margin-bottom: 8px; }
    .legend-inline { display: flex; gap: 24px; flex-wrap: wrap; }
    .legend-item { font-size: 0.9rem; }
    .legend-box { display: inline-block; width: 12px; height: 12px; margin-right: 8px; }
    .achieved-box { background: green; } .not-box { background: red; }
    .analysis-block { padding: 12px 0; border-bottom: 1px solid #ececec; }
    .analysis-block:last-child { border-bottom: none; }
    .analysis-title { font-weight: 700; color: #b32017; margin-bottom: 6px; }
    .analysis-text { font-size: 0.95rem; color: #333; }
</style>