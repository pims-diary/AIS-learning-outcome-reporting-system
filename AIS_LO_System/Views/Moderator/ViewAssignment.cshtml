@model AIS_LO_System.Models.Assignment
@using AIS_LO_System.Models
@{
    ViewData["Title"] = "Review: Assignment Document";
    Layout = "_DashboardLayout";
    var submission = ViewBag.Submission as CourseSubmission;
    var latest = Model.Files?.OrderByDescending(f => f.VersionNumber).FirstOrDefault();
}

<link rel="stylesheet" href="~/css/moderator.css" />
<link rel="stylesheet" href="~/css/assignment-information.css" />

<div class="mod-page">
    <div class="mod-doc-header">
        <a asp-action="Inbox" class="mod-back">← Back to Inbox</a>
        <h1>Assignment Document — @Model.AssessmentName</h1>
        <span class="mod-card-course">@ViewBag.CourseCode @ViewBag.Year T@(ViewBag.Trimester)</span>
    </div>

    @await Component.InvokeAsync("SubmissionStatus", new { submission })

    @if (latest != null)
    {
        var isPdf = latest.FilePath.EndsWith(".pdf");
        var isDocx = latest.FilePath.EndsWith(".docx");
        var cacheBust = $"?v={latest.UploadDate.Ticks}";

        @if (isPdf)
        {
            <iframe src="@(latest.FilePath)@(cacheBust)" class="mod-doc-frame"></iframe>
        }
        else if (isDocx)
        {
            <!-- FIX #7: Add inline preview for .docx files using mammoth.js -->
            <div class="mod-doc-download">
                <a href="@(latest.FilePath)" download class="mod-btn-view">⬇ Download Assignment Document</a>
            </div>

            <div id="docx-loading" class="docx-loading" style="margin-top:20px;">
                <div class="loading-spinner"></div>
                <span>Loading document preview…</span>
            </div>
            <div id="docx-preview" class="docx-preview-frame" style="display:none; margin-top:20px;"></div>

            <script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.8.0/mammoth.browser.min.js"></script>
            <script>
                (function () {
                const url = "@(latest.FilePath)@(cacheBust)";
                const loading = document.getElementById("docx-loading");
                const preview = document.getElementById("docx-preview");

                fetch(url)
                .then(r => r.arrayBuffer())
                .then(buffer => mammoth.convertToHtml({ arrayBuffer: buffer }))
                .then(result => {
                preview.innerHTML = result.value;
                preview.style.display = "block";
                loading.style.display = "none";
                })
                .catch(err => {
                loading.innerHTML = "<span style='color:#999;'>Could not preview this document. Please use the download button above.</span>";
                console.error("DOCX preview error:", err);
                });
                })();
            </script>
        }
        else
        {
            <div class="mod-doc-download">
                <a href="@latest.FilePath" download class="mod-btn-view">⬇ Download Assignment Document</a>
            </div>
        }
        <p class="mod-doc-meta">Version @latest.VersionNumber · Uploaded @latest.UploadDate.ToString("dd MMM yyyy, h:mm tt")</p>
    }
    else
    {
        <div class="mod-empty">No assignment document has been uploaded yet.</div>
    }
</div>

<style>
    /* Docx preview styles */
    .docx-preview-frame {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 32px 40px;
    max-height: 700px;
    overflow-y: auto;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: #1a1a1a;
    }

    .docx-preview-frame h1, .docx-preview-frame h2, .docx-preview-frame h3 {
    color: #2B579A;
    margin-top: 20px;
    }

    .docx-preview-frame table {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    }

    .docx-preview-frame td, .docx-preview-frame th {
    border: 1px solid #d0d0d0;
    padding: 8px 12px;
    text-align: left;
    }

    .docx-preview-frame img {
    max-width: 100%;
    height: auto;
    }

    .docx-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 40px 20px;
    color: #888;
    font-size: 14px;
    }

    .loading-spinner {
    width: 22px;
    height: 22px;
    border: 3px solid #e0e0e0;
    border-top-color: #2B579A;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
    to {
    transform: rotate(360deg);
    }
    }
</style>