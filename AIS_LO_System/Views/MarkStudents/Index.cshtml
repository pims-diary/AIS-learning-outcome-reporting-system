@model AIS_LO_System.Models.MarkStudents.MarkStudentsViewModel

@{
    ViewData["Title"] = "Mark Students";
    Layout = "_DashboardLayout";
}

<div class="container mt-4">

    <!-- Breadcrumb -->
    <div class="breadcrumb mb-3">
        <a class="crumb-link"
               asp-controller="CourseDashboard"
               asp-action="Index"
               asp-route-courseCode="@Model.CourseCode"
               asp-route-year="@Model.Year"
               asp-route-trimester="@Model.Trimester">
            @Model.CourseCode @ViewBag.CourseTitle
        </a>

        <span>/</span>

        <a class="crumb-link"
               asp-controller="Assignment"
               asp-action="Index"
               asp-route-assessmentName="@Model.AssessmentName"
               asp-route-courseCode="@Model.CourseCode"
               asp-route-courseTitle="@ViewBag.CourseTitle"
               asp-route-year="@Model.Year"
               asp-route-trimester="@Model.Trimester">
            Assessments
        </a>

        <span>/</span>
        <span>Mark Students</span>
    </div>

    <!-- Page Title + Back Button -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Mark Students</h2>

        <a class="btn btn-outline-secondary"
               asp-controller="Assignment"
               asp-action="Index"
               asp-route-assessmentName="@Model.AssessmentName"
               asp-route-courseCode="@Model.CourseCode"
               asp-route-courseTitle="@ViewBag.CourseTitle"
               asp-route-year="@Model.Year"
               asp-route-trimester="@Model.Trimester">
            ← Back
        </a>
    </div>

    @await Component.InvokeAsync("SubmissionStatus", new { submission = ViewBag.Submission as AIS_LO_System.Models.CourseSubmission })

    <!-- Card -->
    <div class="card shadow-sm">
        <div class="card-body">

            <!-- Student List Header -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="fw-bold mb-1">Student List</h5>
                    <small class="text-muted">
                        Students Enrolled: @Model.Students.Count
                    </small>
                </div>

                <!-- Search Form -->
                <form method="get"
                      asp-controller="MarkStudents"
                      asp-action="Index"
                      class="d-flex gap-2">

                    <input type="hidden" name="assignmentId" value="@ViewBag.AssignmentId" />
                    <input type="hidden" name="courseCode" value="@Model.CourseCode" />
                    <input type="hidden" name="courseTitle" value="@ViewBag.CourseTitle" />
                    <input type="hidden" name="assessmentName" value="@Model.AssessmentName" />
                    <input type="hidden" name="year" value="@Model.Year" />
                    <input type="hidden" name="trimester" value="@Model.Trimester" />

                    <input type="text"
                           id="studentSearch"
                           name="searchTerm"
                           value="@Model.SearchTerm"
                           class="form-control"
                           placeholder="Search student by ID or name"
                           style="width:280px;" />

                    <button type="submit" class="btn btn-outline-secondary">
                        Search
                    </button>
                </form>
            </div>

            <!-- Students Table -->
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Student ID</th>
                            <th>Student Name</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Students.Any())
                        {
                            foreach (var student in Model.Students)
                            {
                                <tr>
                                    <td>@student.StudentId</td>
                                    <td>@student.StudentName</td>

                                    <td>
                                        @if (student.IsMarked)
                                        {
                                            <span class="status-marked">Marked</span>
                                        }
                                        else
                                        {
                                            <span class="status-not-marked">Not Marked</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <a asp-controller="MarkStudents"
                                               asp-action="MarkStudent"
                                               asp-route-studentId="@student.InternalId"
                                               asp-route-assignmentId="@ViewBag.AssignmentId"
                                               asp-route-courseCode="@Model.CourseCode"
                                               asp-route-courseTitle="@ViewBag.CourseTitle"
                                               asp-route-assessmentName="@Model.AssessmentName"
                                               asp-route-year="@Model.Year"
                                               asp-route-trimester="@Model.Trimester"
                                               class="action-btn">
                                            @(student.IsMarked ? "View" : "Mark Student")
                                        </a>

                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No students found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("studentSearch");

        if (searchInput) {
            searchInput.addEventListener("input", function () {
                if (this.value.trim() === "") {
                    this.form.submit();
                }
            });
        }
    });
</script>