@model AIS_LO_System.Models.MarkStudents.MarkStudentsViewModel

@{
    ViewData["Title"] = "Mark Students";
    Layout = "_DashboardLayout";
    var studentMarksSubmission = ViewBag.StudentMarksSubmission as AIS_LO_System.Models.CourseSubmission;
    var loAchievementSubmission = ViewBag.LOAchievementSubmission as AIS_LO_System.Models.CourseSubmission;
    var canSubmitLoAchievementBatch =
        loAchievementSubmission == null || loAchievementSubmission.Status != AIS_LO_System.Models.SubmissionStatus.Pending;
}

<div class="container mt-4">

    @await Html.PartialAsync("_PageHeader", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        { "Breadcrumbs", new List<(string Label, string? Controller, string? Action, object? RouteValues)>
            {
                ($"{Model.CourseCode} {Model.Year} - T{Model.Trimester}", "CourseDashboard", "Index", new { courseCode = Model.CourseCode, year = Model.Year, trimester = Model.Trimester }),
                (Model.AssessmentName, "Assignment", "Index", new { assessmentName = Model.AssessmentName, courseCode = Model.CourseCode, courseTitle = ViewBag.CourseTitle, year = Model.Year, trimester = Model.Trimester }),
                ("Mark Students", null, null, null)
            }
        },
        { "BackController",  "Assignment" },
        { "BackAction",      "Index" },
        { "BackRouteValues", new { assessmentName = Model.AssessmentName, courseCode = Model.CourseCode, courseTitle = ViewBag.CourseTitle, year = Model.Year, trimester = Model.Trimester } as object },
    })

    <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
        <h2 class="fw-bold mb-0">Mark Students</h2>

        @if (canSubmitLoAchievementBatch)
        {
            <form asp-controller="MarkStudents"
                  asp-action="SubmitLOAchievementReports"
                  method="post"
                  class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="assignmentId" value="@ViewBag.AssignmentId" />
                <input type="hidden" name="courseCode" value="@Model.CourseCode" />
                <input type="hidden" name="courseTitle" value="@ViewBag.CourseTitle" />
                <input type="hidden" name="assessmentName" value="@Model.AssessmentName" />
                <input type="hidden" name="year" value="@Model.Year" />
                <input type="hidden" name="trimester" value="@Model.Trimester" />
                <button type="submit"
                        class="ais-red-btn">
                    Submit LO Achievement Batch
                </button>
            </form>
        }
    </div>

    @if (studentMarksSubmission != null || loAchievementSubmission != null)
    {
        <div class="submission-status-stack">
            @if (studentMarksSubmission != null)
            {
                <div class="submission-status-item">
                    <div class="submission-status-label">Student Marks</div>
                    @await Component.InvokeAsync("SubmissionStatus", new { submission = studentMarksSubmission })
                </div>
            }

            @if (loAchievementSubmission != null)
            {
                <div class="submission-status-item">
                    <div class="submission-status-label">LO Achievement</div>
                    @await Component.InvokeAsync("SubmissionStatus", new { submission = loAchievementSubmission })
                </div>
            }
        </div>
    }

    <!-- Card -->
    <div class="card shadow-sm">
        <div class="card-body">

            <!-- Student List Header -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="fw-bold mb-1">Student List</h5>
                    <small class="text-muted">
                        Students Enrolled: @Model.Students.Count
                    </small>
                </div>

                <!-- Search Form -->
                <form method="get"
                      asp-controller="MarkStudents"
                      asp-action="Index"
                      class="d-flex gap-2">

                    <input type="hidden" name="assignmentId" value="@ViewBag.AssignmentId" />
                    <input type="hidden" name="courseCode" value="@Model.CourseCode" />
                    <input type="hidden" name="courseTitle" value="@ViewBag.CourseTitle" />
                    <input type="hidden" name="assessmentName" value="@Model.AssessmentName" />
                    <input type="hidden" name="year" value="@Model.Year" />
                    <input type="hidden" name="trimester" value="@Model.Trimester" />

                    <input type="text"
                           id="studentSearch"
                           name="searchTerm"
                           value="@Model.SearchTerm"
                           class="form-control"
                           placeholder="Search student by ID or name"
                           style="width:280px;" />

                    <button type="submit" class="btn btn-outline-secondary">
                        Search
                    </button>
                </form>
            </div>

            <!-- Students Table -->
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Student ID</th>
                            <th>Student Name</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Students.Any())
                        {
                            foreach (var student in Model.Students)
                            {
                                <tr>
                                    <td>@student.StudentId</td>
                                    <td>@student.StudentName</td>

                                    <td>
                                        @if (student.IsMarked)
                                        {
                                            <span class="ais-pill ais-pill-success">Marked</span>
                                        }
                                        else
                                        {
                                            <span class="ais-pill ais-pill-danger">Not Marked</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <a asp-controller="MarkStudents"
                                               asp-action="MarkStudent"
                                               asp-route-studentId="@student.InternalId"
                                               asp-route-assignmentId="@ViewBag.AssignmentId"
                                               asp-route-courseCode="@Model.CourseCode"
                                               asp-route-courseTitle="@ViewBag.CourseTitle"
                                               asp-route-assessmentName="@Model.AssessmentName"
                                               asp-route-year="@Model.Year"
                                               asp-route-trimester="@Model.Trimester"
                                               class="action-btn">
                                            @(student.IsMarked ? "View" : "Mark Student")
                                        </a>

                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No students found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("studentSearch");

        if (searchInput) {
            searchInput.addEventListener("input", function () {
                if (this.value.trim() === "") {
                    this.form.submit();
                }
            });
        }
    });
</script>

<style>
    .submission-status-stack {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 20px;
    }

    .submission-status-item {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .submission-status-label {
        min-width: 130px;
        font-size: 0.95rem;
        font-weight: 700;
        color: #374151;
    }

    /* Match Image 3, but not oversized */
    .ais-red-btn {
        background-color: #c21c00;
        color: white;
        padding: 10px 22px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        line-height: 1.2;
        white-space: nowrap;
    }

    .ais-red-btn:hover {
        filter: brightness(0.95);
    }

    .ais-pill {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
        border: 1px solid transparent;
        line-height: 1.1;
        white-space: nowrap;
    }

    .ais-pill-success {
        background: #ecfdf5;
        border-color: #d1fae5;
        color: #065f46;
    }

    .ais-pill-danger {
        background: #fef2f2;
        border-color: #fee2e2;
        color: #991b1b;
    }
</style>
