@model AIS_LO_System.Models.MarkStudents.LOAchievementReportViewModel
@using AIS_LO_System.Models

@{
    ViewData["Title"] = "LO Achievement Report";
    Layout = "_DashboardLayout";
    var loSubmission = ViewBag.Submission as CourseSubmission;
}

<div class="container mt-4 lo-report-page">

    @await Html.PartialAsync("_PageHeader", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        { "Breadcrumbs", new List<(string Label, string? Controller, string? Action, object? RouteValues)>
            {
                ($"{Model.CourseCode} {Model.Year} - T{Model.Trimester}", "CourseDashboard", "Index", new { courseCode = Model.CourseCode, year = Model.Year, trimester = Model.Trimester }),
                (Model.AssessmentName, "Assignment", "Index", new { assessmentName = Model.AssessmentName, courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, year = Model.Year, trimester = Model.Trimester }),
                ("Mark Students", "MarkStudents", "Index", new { assignmentId = Model.AssignmentId, courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, assessmentName = Model.AssessmentName, year = Model.Year, trimester = Model.Trimester }),
                ("LO Achievement Report", null, null, null)
            }
        },
        { "BackController",  "MarkStudents" },
        { "BackAction",      "MarkStudent" },
        { "BackRouteValues", new { studentId = Model.StudentInternalId, assignmentId = Model.AssignmentId, courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, assessmentName = Model.AssessmentName, year = Model.Year, trimester = Model.Trimester } as object },
    })

    @if (loSubmission != null)
    {
        @await Component.InvokeAsync("SubmissionStatus", new { submission = loSubmission })
    }

    <div class="report-card">
        <div class="report-header d-flex justify-content-between align-items-start mb-3">
            <h2 class="report-title">LO Achievement Report for <em>@Model.StudentName</em></h2>


        </div>

        <!-- Top page info -->
        <div class="page-info-box">
            <div><strong>Individual Assignment</strong></div>
            <div><strong>Assessment Weight:</strong> @Model.AssessmentWeight.ToString("0")%</div>
        </div>

        <!-- Bigger full-width chart -->
        <div class="chart-section">
            <div class="chart-box">
                <div class="y-axis-label top">100</div>
                <div class="chart-grid">
                    <div class="grid-line line-80"></div>
                    <div class="grid-line line-60"></div>
                    <div class="grid-line line-40"></div>
                    <div class="grid-line line-20"></div>

                    <div class="bars-wrap">
                        @foreach (var lo in Model.LearningOutcomes)
                        {
                            var barClass = lo.Status == "Achieved"
                            ? "bar-achieved"
                            : "bar-not-achieved";

                            <div class="bar-item">
                                <div class="bar-percent">@lo.Percentage.ToString("0.##")%</div>
                                <div class="bar @barClass" style="height:@lo.Percentage%;"></div>
                                <div class="bar-label">@lo.Label</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Graph related info below chart -->
            <div class="chart-info-box">
                <div class="chart-info-status">@Model.OverallStatusText</div>

                <div class="legend-inline">
                    <div class="legend-item">
                        <span class="legend-box achieved-box"></span> Achieved
                    </div>
                    <div class="legend-item">
                        <span class="legend-box not-box"></span> Not Achieved
                    </div>
                </div>
            </div>
        </div>

        <hr class="section-divider" />

        <h3 class="section-title">Learning Outcome Insights</h3>

        @foreach (var lo in Model.LearningOutcomes)
        {
            <div class="lo-insight-block mb-4">
                <p class="mb-1"><strong>@lo.Label: @lo.Percentage.ToString("0.##")% Achieved</strong></p>

                @if (!lo.Insights.Any())
                {
                    <p class="text-muted fst-italic ms-3 mb-0">No significant weaknesses identified.</p>
                }
                else
                {
                    @if (lo.Status == "Not Achieved")
                    {
                        <p class="ms-3 mb-2">Low achievement in @lo.Label is mainly due to:</p>
                    }
                    else
                    {
                        <p class="ms-3 mb-2">Achievement details for @lo.Label:</p>
                    }

                    @foreach (var insight in lo.Insights)
                    {
                        <div class="ms-4 mb-2">
                            <div><strong>@insight.CriterionTitle</strong></div>
                            <div class="ms-3">
                                • Rubric Score:
                                <span class="insight-score">@insight.RubricScore (@insight.RubricLabel)</span>
                            </div>
                        </div>
                    }
                }
            </div>
        }

        <hr class="section-divider" />

        <h3 class="section-title mt-4">LO Achievement Results</h3>

        @if (Model.LearningOutcomes.Any())
        {
            <table class="table table-bordered align-middle lo-table">
                <thead>
                    <tr>
                        <th>LO</th>
                        <th>Learning Outcome</th>
                        <th>Achieved Score</th>
                        <th>Max Score</th>
                        <th>Percentage</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lo in Model.LearningOutcomes)
                    {
                        var statusClass = lo.Status == "Achieved"
                        ? "status-achieved"
                        : "status-not-achieved";

                        <tr>
                            <td>@lo.Label</td>
                            <td>@lo.LearningOutcomeText</td>
                            <td>@lo.AchievedScore.ToString("0.00")</td>
                            <td>@lo.MaxScore.ToString("0.00")</td>
                            <td>@lo.Percentage.ToString("0.##")%</td>
                            <td><span class="status-pill @statusClass">@lo.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No learning outcomes found for this assignment.</p>
        }

        <div class="report-actions mt-4">
            <a asp-controller="MarkStudents"
                   asp-action="DownloadLOAchievementReportPdf"
                   asp-route-studentId="@Model.StudentInternalId"
                   asp-route-assignmentId="@Model.AssignmentId"
                   asp-route-courseCode="@Model.CourseCode"
                   asp-route-courseTitle="@Model.CourseTitle"
                   asp-route-assessmentName="@Model.AssessmentName"
                   asp-route-year="@Model.Year"
                   asp-route-trimester="@Model.Trimester"
                   style="background-color:#c21c00;color:white;padding:10px 22px;border-radius:10px;font-size:15px;font-weight:600;border:none;text-decoration:none;display:inline-block;line-height:1.2;white-space:nowrap;">
                Download PDF
            </a>

            <a asp-controller="MarkStudents"
                   asp-action="MarkStudent"
                   asp-route-studentId="@Model.StudentInternalId"
                   asp-route-assignmentId="@Model.AssignmentId"
                   asp-route-courseCode="@Model.CourseCode"
                   asp-route-courseTitle="@Model.CourseTitle"
                   asp-route-assessmentName="@Model.AssessmentName"
                   asp-route-year="@Model.Year"
                   asp-route-trimester="@Model.Trimester"
                   style="background-color:#c21c00;color:white;padding:10px 22px;border-radius:10px;font-size:15px;font-weight:600;border:none;text-decoration:none;display:inline-block;line-height:1.2;white-space:nowrap;">
                Cancel
            </a>
        </div>
    </div>
</div>

<style>
    .lo-report-page {
        max-width: 1200px;
    }

    .report-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        padding: 28px;
    }

    .report-title {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
    }

    .back-link {
        color: #111;
        text-decoration: underline;
        font-weight: 600;
    }

    .page-info-box {
        display: flex;
        gap: 30px;
        align-items: center;
        font-size: 1rem;
        margin-bottom: 22px;
        padding-bottom: 14px;
        border-bottom: 1px solid #d9d9d9;
    }

    .chart-section {
        margin-bottom: 10px;
    }

    .chart-box {
        position: relative;
        padding-left: 34px;
        padding-top: 18px;
    }

    .y-axis-label.top {
        position: absolute;
        left: 0;
        top: 0;
        font-size: 0.95rem;
        color: #c62828;
        font-weight: 700;
    }

    .chart-grid {
        position: relative;
        height: 360px;
        border-left: 2px solid #555;
        border-bottom: 2px solid #555;
        margin-top: 10px;
    }

    .grid-line {
        position: absolute;
        left: 0;
        right: 0;
        border-top: 1px solid #bbb;
    }

    .line-80 {
        top: 20%;
    }

    .line-60 {
        top: 40%;
    }

    .line-40 {
        top: 60%;
    }

    .line-20 {
        top: 80%;
    }

    .bars-wrap {
        position: absolute;
        left: 30px;
        right: 30px;
        bottom: 0;
        top: 0;
        display: flex;
        justify-content: space-around;
        align-items: flex-end;
        padding-bottom: 36px;
    }

    .bar-item {
        width: 90px;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        align-items: center;
    }

    .bar {
        width: 40px;
        min-height: 2px;
        border: 1px solid #555;
    }

    .bar-percent {
        font-size: 1rem;
        color: #c62828;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .bar-label {
        margin-top: 8px;
        font-size: 0.95rem;
        color: #c62828;
        font-weight: 600;
    }

    .bar-achieved {
        background: green;
    }

    .bar-not-achieved {
        background: red;
    }

    .chart-info-box {
        margin-top: 16px;
        padding: 12px 14px;
        background: #fafafa;
        border: 1px solid #e1e1e1;
        border-radius: 6px;
        font-size: 0.92rem;
    }

    .chart-info-status {
        font-weight: 700;
        color: #b32017;
        margin-bottom: 8px;
    }

    .legend-inline {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

    .legend-item {
        font-size: 0.9rem;
    }

    .legend-box {
        display: inline-block;
        width: 12px;
        height: 12px;
        margin-right: 8px;
    }

    .achieved-box {
        background: green;
    }

    .not-box {
        background: red;
    }

    .section-divider {
        border: none;
        border-top: 1px solid #d9d9d9;
        margin: 24px 0;
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .insight-score {
        color: #d32f2f;
        font-weight: 600;
    }

    .status-pill {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .status-achieved {
        background-color: #d1fae5;
        color: #065f46;
    }

    .status-not-achieved {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .report-actions {
        display: flex;
        justify-content: center;
        gap: 18px;
    }

    .report-btn {
        min-width: 120px;
        background: #b32017;
        color: #fff;
        border: none;
    }

        .report-btn:hover {
            background: #8f1a12;
            color: #fff;
        }
</style>