@model AIS_LO_System.Models.MarkStudents.MarkStudentViewModel

@{
    ViewData["Title"] = "Mark Student";
    Layout = "_DashboardLayout";
    var isImpersonated = !string.IsNullOrEmpty(User.FindFirst("ImpersonatedBy")?.Value);
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="container mt-4">

    <div class="breadcrumb mb-3">
        <a class="crumb-link"
           asp-controller="CourseDashboard"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            @Model.CourseCode @Model.CourseTitle
        </a>

        <span>/</span>

        <a class="crumb-link"
           asp-controller="Assignment"
           asp-action="Index"
           asp-route-assessmentName="@Model.AssessmentName"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            Assessments
        </a>

        <span>/</span>

        <a class="crumb-link"
           asp-controller="MarkStudents"
           asp-action="Index"
           asp-route-assignmentId="@Model.AssignmentId"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-assessmentName="@Model.AssessmentName"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            Mark Students
        </a>

        <span>/</span>
        <span>@Model.StudentName</span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">@Model.StudentName</h2>

        <a asp-controller="MarkStudents"
           asp-action="Index"
           asp-route-assignmentId="@Model.AssignmentId"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-assessmentName="@Model.AssessmentName"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester"
           class="btn btn-outline-secondary">
            ← Back
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <form asp-controller="MarkStudents" asp-action="SaveMarks" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="assignmentId" value="@Model.AssignmentId" />
                <input type="hidden" name="studentId" value="@Model.StudentInternalId" />
                <input type="hidden" name="courseCode" value="@Model.CourseCode" />
                <input type="hidden" name="courseTitle" value="@Model.CourseTitle" />
                <input type="hidden" name="assessmentName" value="@Model.AssessmentName" />
                <input type="hidden" name="year" value="@Model.Year" />
                <input type="hidden" name="trimester" value="@Model.Trimester" />
                <input type="hidden" id="selectedLevelsJson" name="selectedLevelsJson" />

                <div class="row mb-3">
                    <div class="col-md-3">
                        <strong>Student ID:</strong> @Model.StudentId
                    </div>
                    <div class="col-md-3">
                        <strong>Assessment:</strong> @Model.AssessmentName
                    </div>
                    <div class="col-md-3">
                        <strong>Rubric Scale:</strong>
                        @if (Model.Levels.Any())
                        {
                            <span>@Model.Levels.Max() – @Model.Levels.Min()</span>
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </div>
                    <div class="col-md-3">
                        <strong>Total Weight:</strong> @Model.TotalWeight
                    </div>
                </div>

                <div class="table-responsive" style="overflow-x: visible;">
                    <table class="table table-bordered rubric-marking-table align-middle text-center">
                        <thead>
                            <tr>
                                <th class="criteria-col">Criteria</th>
                                <th class="weight-col">Weight</th>
                                <th class="lo-col">LOs</th>
                                @foreach (var level in Model.Levels)
                                {
                                    <th class="level-header-col">@level</th>
                                }
                                <th class="marks-col">Calculated Marks</th>
                            </tr>
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                @foreach (var level in Model.Levels)
                                {
                                    var levelName = Model.Criteria
                                    .SelectMany(c => c.LevelDescriptions)
                                    .FirstOrDefault(l => l.Score == level)?.ScaleName ?? "";

                                    <th class="scale-name-header">@levelName</th>
                                }
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Criteria.Any())
                            {
                                int rowNo = 1;

                                foreach (var criterion in Model.Criteria)
                                {
                                    <tr>
                                        <td class="text-start criterion-text">
                                            @rowNo. @criterion.CriterionTitle
                                        </td>

                                        <td>@criterion.Weight</td>
                                        <td>@criterion.LOs</td>

                                        @foreach (var level in Model.Levels)
                                        {
                                            var levelInfo = criterion.LevelDescriptions
                                            .FirstOrDefault(l => l.Score == level);

                                            <td class="level-desc-cell">
                                                @if (levelInfo != null)
                                                {
                                                    var isSelected = criterion.SelectedLevel == level ? "selected" : "";

                                                    <button type="button"
                                                            class="level-btn rubric-cell-btn @isSelected"
                                                            data-criterion-id="@criterion.CriterionId"
                                                            data-level="@level"
                                                            data-weight="@criterion.Weight"
                                                            @(isImpersonated ? "disabled" : "")>
                                                        <div class="cell-score">@level</div>
                                                        <div class="cell-scale">@levelInfo.ScaleName</div>
                                                        <div class="cell-description">
                                                            @levelInfo.Description
                                                        </div>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        }

                                        <td class="calculated-marks fw-semibold"
                                            data-criterion-id="@criterion.CriterionId">
                                            @criterion.CalculatedMarks.ToString("0.00")
                                        </td>
                                    </tr>

                                    rowNo++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(Model.Levels.Count + 4)" class="text-center text-muted">
                                        No rubric criteria found.
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="@(Model.Levels.Count + 3)" class="text-end">Total Score</th>
                                <th id="total-score">@Model.TotalScore.ToString("0.00")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="mt-3">
                    <label class="form-label fw-semibold">Comments</label>
                    <textarea class="form-control"
                              rows="3"
                              name="comment"
                              placeholder="Add comments here..."
                              @(isImpersonated ? "disabled" : "")>@Model.Comment</textarea>
                </div>

                <div class="mt-3 d-flex justify-content-end gap-2">
                    <a asp-controller="MarkStudents"
                       asp-action="LOAchievementReport"
                       asp-route-studentId="@Model.StudentInternalId"
                       asp-route-assignmentId="@Model.AssignmentId"
                       asp-route-courseCode="@Model.CourseCode"
                       asp-route-courseTitle="@Model.CourseTitle"
                       asp-route-assessmentName="@Model.AssessmentName"
                       asp-route-year="@Model.Year"
                       asp-route-trimester="@Model.Trimester"
                       class="btn btn-warning">
                        View LO Achievement Result
                    </a>

                    <button type="submit" class="btn btn-danger" @(isImpersonated ? "disabled" : "")>
                        Save Marks
                    </button>

                    <button type="submit"
                            form="clearMarksForm"
                            class="btn btn-outline-danger"
                            @(isImpersonated ? "disabled" : "")>
                        Clear Marks
                    </button>
                </div>
            </form>

        </div>
    </div>

</div>

<form id="clearMarksForm" asp-controller="MarkStudents" asp-action="ClearMarks" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="assignmentId" value="@Model.AssignmentId" />
    <input type="hidden" name="studentId" value="@Model.StudentInternalId" />
    <input type="hidden" name="courseCode" value="@Model.CourseCode" />
    <input type="hidden" name="courseTitle" value="@Model.CourseTitle" />
    <input type="hidden" name="assessmentName" value="@Model.AssessmentName" />
    <input type="hidden" name="year" value="@Model.Year" />
    <input type="hidden" name="trimester" value="@Model.Trimester" />
</form>

<style>
    .rubric-marking-table {
        width: 100%;
        table-layout: fixed; /* IMPORTANT: forces equal column fit */
        font-size: 0.85rem; /* reduce overall text */
    }

        .rubric-marking-table th,
        .rubric-marking-table td {
            vertical-align: top;
            padding: 6px;
            word-wrap: break-word;
        }

    .criteria-col {
        width: 18%;
    }

    .weight-col,
    .lo-col,
    .marks-col {
        width: 6%;
    }

    .level-header-col {
        width: 14%;
        font-size: 1.2rem;
        font-weight: 600;
    }

    .scale-name-header {
        font-size: 0.8rem;
        font-weight: 500;
    }

    .criterion-text {
        font-size: 0.85rem;
        line-height: 1.2;
    }

    .level-desc-cell {
        padding: 0 !important;
    }

    .rubric-cell-btn {
        width: 100%;
        min-height: 120px;
        border: none; /* removes inner box */
        background: transparent; /* removes inner background */
        cursor: pointer;
        padding: 6px;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 3px;
        font-size: 0.8rem;
    }

        .rubric-cell-btn:hover {
            background-color: rgba(0,0,0,0.05);
        }

        .rubric-cell-btn.selected {
    background-color: #b32017 !important;
    color: #fff !important;
}

    .cell-score {
        font-size: 0.95rem;
        font-weight: 700;
        text-align: center;
    }

    .cell-scale {
        font-size: 0.8rem;
        font-weight: 600;
        text-align: center;
    }

    .cell-description {
        font-size: 0.75rem; /* smaller text */
        line-height: 1.2;
    }
</style>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const buttons = document.querySelectorAll(".level-btn");
        const selectedLevels = {};

        function updateTotalScore() {
            let total = 0;

            document.querySelectorAll(".calculated-marks").forEach(function (cell) {
                const value = parseFloat(cell.textContent);
                if (!isNaN(value)) {
                    total += value;
                }
            });

            const totalScoreCell = document.getElementById("total-score");
            if (totalScoreCell) {
                totalScoreCell.textContent = total.toFixed(2);
            }
        }

        function updateHiddenJson() {
            const arr = Object.keys(selectedLevels).map(key => ({
                CriterionId: parseInt(key),
                SelectedLevel: selectedLevels[key]
            }));

            const hidden = document.getElementById("selectedLevelsJson");
            if (hidden) {
                hidden.value = JSON.stringify(arr);
            }
        }

        document.querySelectorAll(".level-btn.selected").forEach(function (btn) {
            const criterionId = btn.getAttribute("data-criterion-id");
            const selectedLevel = parseFloat(btn.getAttribute("data-level"));
            selectedLevels[criterionId] = selectedLevel;
        });

        updateHiddenJson();
        updateTotalScore();

        buttons.forEach(function (button) {
            button.addEventListener("click", function () {
                if (this.disabled) return;

                const criterionId = this.getAttribute("data-criterion-id");
                const selectedLevel = parseFloat(this.getAttribute("data-level"));
                const weight = parseFloat(this.getAttribute("data-weight"));
                const calculated = selectedLevel * weight;

                document.querySelectorAll(".level-btn").forEach(function (btn) {
                    if (btn.getAttribute("data-criterion-id") === criterionId) {
                        btn.classList.remove("selected");
                    }
                });

                this.classList.add("selected");

                const marksCell = document.querySelector(".calculated-marks[data-criterion-id='" + criterionId + "']");
                if (marksCell) {
                    marksCell.textContent = calculated.toFixed(2);
                }

                selectedLevels[criterionId] = selectedLevel;
                updateHiddenJson();
                updateTotalScore();
            });
        });
    });
</script>