@model AIS_LO_System.Models.MarkStudents.MarkStudentViewModel

@{
    ViewData["Title"] = "Mark Student";
}

<div class="container mt-4">

    <!-- Breadcrumb -->
    <div class="breadcrumb mb-3">
        <a class="crumb-link"
           asp-controller="CourseDashboard"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            @Model.CourseCode @Model.CourseTitle
        </a>

        <span>/</span>

        <a class="crumb-link"
           asp-controller="Assignment"
           asp-action="Index"
           asp-route-assessmentName="@Model.AssessmentName"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            Assessments
        </a>

        <span>/</span>

        <a class="crumb-link"
           asp-controller="MarkStudents"
           asp-action="Index"
           asp-route-assignmentId="@Model.AssignmentId"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-assessmentName="@Model.AssessmentName"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            Mark Students
        </a>

        <span>/</span>
        <span>@Model.StudentName</span>
    </div>

    <!-- Title + Back -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">@Model.StudentName</h2>

        <a asp-controller="MarkStudents"
           asp-action="Index"
           asp-route-assignmentId="@Model.AssignmentId"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-assessmentName="@Model.AssessmentName"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester"
           class="btn btn-outline-secondary">
            ← Back
        </a>
    </div>

    <!-- Summary Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-3">
                    <strong>Student ID:</strong> @Model.StudentId
                </div>
                <div class="col-md-3">
                    <strong>Assessment:</strong> @Model.AssessmentName
                </div>
                <div class="col-md-3">
                    <strong>Rubric Scale:</strong>
                    @if (Model.Levels.Any())
                    {
                        <span>@Model.Levels.Max() – @Model.Levels.Min()</span>
                    }
                    else
                    {
                        <span>N/A</span>
                    }
                </div>
                <div class="col-md-3">
                    <strong>Total Weight:</strong> @Model.TotalWeight
                </div>
            </div>

            <!-- Rubric Table -->
            <div class="table-responsive">
                <table class="table table-bordered align-middle text-center">
                    <thead>
                        <tr>
                            <th class="text-start">Criteria</th>
                            <th>Weight</th>
                            <th>LOs</th>
                            @foreach (var level in Model.Levels)
                            {
                                <th>@level</th>
                            }
                            <th>Calculated Marks</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Criteria.Any())
                        {
                            foreach (var criterion in Model.Criteria)
                            {
                                <tr>
                                    <td class="text-start">@criterion.CriterionTitle</td>
                                    <td class="criterion-weight" data-weight="@criterion.Weight">
                                        @criterion.Weight
                                    </td>
                                    <td>@criterion.LOs</td>

                                    @foreach (var level in Model.Levels)
                                    {
                                        <td>
                                            @if (criterion.AvailableLevels.Contains(level))
                                            {
                                                <button type="button"
                                                        class="level-btn"
                                                        data-criterion-id="@criterion.CriterionId"
                                                        data-level="@level"
                                                        data-weight="@criterion.Weight">
                                                    @level
                                                </button>
                                                }
                                            
                                                else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    }

                                    <td class="calculated-marks" data-criterion-id="@criterion.CriterionId">
                                        0
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted">
                                    No rubric criteria found.
                                </td>
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr>
                            <th colspan="@(Model.Levels.Count + 3)" class="text-end">Total Score</th>
                            <th>@Model.TotalScore</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- Comments -->
            <div class="mt-3">
                <label class="form-label fw-semibold">Comments</label>
                <textarea class="form-control" rows="3" placeholder="Add comments here..." disabled></textarea>
            </div>

        </div>
    </div>
    

</div>

<style>
    .level-btn {
        min-width: 40px;
        padding: 4px 10px;
        border: 1px solid #ccc;
        background-color: #fff;
        border-radius: 6px;
        cursor: pointer;
    }

        .level-btn:hover {
            background-color: #f5f5f5;
        }

        .level-btn.selected {
            background-color: #b32017 !important;
            color: #fff !important;
            border-color: #b32017 !important;
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const buttons = document.querySelectorAll(".level-btn");
        console.log("Buttons found:", buttons.length);

        buttons.forEach(button => {
            button.addEventListener("click", function () {
                const criterionId = this.getAttribute("data-criterion-id");
                const selectedLevel = parseFloat(this.getAttribute("data-level"));
                const weight = parseFloat(this.getAttribute("data-weight"));

                // remove selected from same criterion row
                document.querySelectorAll(".level-btn").forEach(btn => {
                    if (btn.getAttribute("data-criterion-id") === criterionId) {
                        btn.classList.remove("selected");
                    }
                });

                // highlight clicked button
                this.classList.add("selected");

                // calculate row marks = selected level × weight
                const calculated = selectedLevel * weight;

                // show row marks in Calculated Marks column
                const marksCell = document.querySelector(`.calculated-marks[data-criterion-id='${criterionId}']`);
                if (marksCell) {
                    marksCell.textContent = calculated.toFixed(2);
                }
            });
        });
    });
</script>
