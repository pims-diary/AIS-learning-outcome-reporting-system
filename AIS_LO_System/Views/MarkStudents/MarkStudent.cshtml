@model AIS_LO_System.Models.MarkStudents.MarkStudentViewModel

@{
    ViewData["Title"] = "Mark Student";
    Layout = "_DashboardLayout";
    var isImpersonated = !string.IsNullOrEmpty(User.FindFirst("ImpersonatedBy")?.Value);
    var errorMessage = TempData["Error"] as string;
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="container mt-4">

    @await Html.PartialAsync("_PageHeader", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        { "Breadcrumbs", new List<(string Label, string? Controller, string? Action, object? RouteValues)>
            {
                ($"{Model.CourseCode} {Model.Year} - T{Model.Trimester}", "CourseDashboard", "Index", new { courseCode = Model.CourseCode, year = Model.Year, trimester = Model.Trimester }),
                (Model.AssessmentName, "Assignment", "Index", new { assessmentName = Model.AssessmentName, courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, year = Model.Year, trimester = Model.Trimester }),
                ("Mark Students", "MarkStudents", "Index", new { assignmentId = Model.AssignmentId, courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, assessmentName = Model.AssessmentName, year = Model.Year, trimester = Model.Trimester }),
                (Model.StudentName, null, null, null)
            }
        },
        { "BackController",  "MarkStudents" },
        { "BackAction",      "Index" },
        { "BackRouteValues", new { assignmentId = Model.AssignmentId, courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, assessmentName = Model.AssessmentName, year = Model.Year, trimester = Model.Trimester } as object },
    })

    <div class="d-flex align-items-center mb-3">
        <h2 class="fw-bold mb-0">@Model.StudentName</h2>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <form asp-controller="MarkStudents" asp-action="SaveMarks" method="post" id="saveMarksForm">
                @Html.AntiForgeryToken()

                <input type="hidden" name="assignmentId" value="@Model.AssignmentId" />
                <input type="hidden" name="studentId" value="@Model.StudentInternalId" />
                <input type="hidden" name="courseCode" value="@Model.CourseCode" />
                <input type="hidden" name="courseTitle" value="@Model.CourseTitle" />
                <input type="hidden" name="assessmentName" value="@Model.AssessmentName" />
                <input type="hidden" name="year" value="@Model.Year" />
                <input type="hidden" name="trimester" value="@Model.Trimester" />
                <input type="hidden" id="selectedLevelsJson" name="selectedLevelsJson" />

                <div class="row mb-3">
                    <div class="col-md-3">
                        <strong>Student ID:</strong> @Model.StudentId
                    </div>
                    <div class="col-md-3">
                        <strong>Assessment:</strong> @Model.AssessmentName
                    </div>
                    <div class="col-md-3">
                        <strong>Rubric Scale:</strong>
                        @if (Model.Levels.Any())
                        {
                            <span>@Model.Levels.Max() – @Model.Levels.Min()</span>
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </div>
                    <div class="col-md-3">
                        <strong>Total Weight:</strong> @Model.TotalWeight
                    </div>
                </div>

                <div class="table-responsive" style="overflow-x: visible;">
                    <table class="table table-bordered rubric-marking-table align-middle text-center">
                        <thead>
                            <tr>
                                <th class="criteria-col">Criteria</th>
                                <th class="weight-col">Weight</th>
                                <th class="lo-col">LOs</th>
                                @foreach (var level in Model.Levels)
                                {
                                    <th class="level-header-col">@level</th>
                                }
                                <th class="marks-col">Calculated Marks</th>
                            </tr>
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                @foreach (var level in Model.Levels)
                                {
                                    var levelName = Model.Criteria
                                    .SelectMany(c => c.LevelDescriptions)
                                    .FirstOrDefault(l => l.Score == level)?.ScaleName ?? "";

                                    <th class="scale-name-header">@levelName</th>
                                }
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Criteria.Any())
                            {
                                int rowNo = 1;

                                foreach (var criterion in Model.Criteria)
                                {
                                    <tr>
                                        <td class="text-start criterion-text">
                                            @rowNo. @criterion.CriterionTitle
                                        </td>

                                        <td>@criterion.Weight</td>
                                        <td>@criterion.LOs</td>

                                        @foreach (var level in Model.Levels)
                                        {
                                            var levelInfo = criterion.LevelDescriptions
                                            .FirstOrDefault(l => l.Score == level);

                                            <td class="level-desc-cell">
                                                @if (levelInfo != null)
                                                {
                                                    var isSelected = criterion.SelectedLevel == level ? "selected" : "";

                                                    <button type="button"
                                                            class="level-btn rubric-cell-btn @isSelected"
                                                            data-criterion-id="@criterion.CriterionId"
                                                            data-level="@level"
                                                            data-weight="@criterion.Weight"
                                                        @(isImpersonated ? "disabled" : "")>
                                                        <div class="cell-score">@level</div>
                                                        <div class="cell-scale">@levelInfo.ScaleName</div>
                                                        <div class="cell-description">
                                                            @levelInfo.Description
                                                        </div>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        }

                                        <td class="calculated-marks fw-semibold"
                                            data-criterion-id="@criterion.CriterionId">
                                            @criterion.CalculatedMarks.ToString("0.00")
                                        </td>
                                    </tr>

                                    rowNo++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(Model.Levels.Count + 4)" class="text-center text-muted">
                                        No rubric criteria found.
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="@(Model.Levels.Count + 3)" class="text-end">Total Score</th>
                                <th id="total-score">@Model.TotalScore.ToString("0.00")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="mt-3">
                    <label class="form-label fw-semibold">Comments</label>
                    <textarea class="form-control"
                              rows="3"
                              id="commentInput"
                              name="comment"
                              placeholder="Add comments here..."
                    @(isImpersonated ? "disabled" : "")>@Model.Comment</textarea>
                </div>

                <div class="mt-3 d-flex justify-content-end gap-2">
                    <a asp-controller="MarkStudents"
                           asp-action="LOAchievementReport"
                           asp-route-studentId="@Model.StudentInternalId"
                           asp-route-assignmentId="@Model.AssignmentId"
                           asp-route-courseCode="@Model.CourseCode"
                           asp-route-courseTitle="@Model.CourseTitle"
                           asp-route-assessmentName="@Model.AssessmentName"
                           asp-route-year="@Model.Year"
                           asp-route-trimester="@Model.Trimester"
                           id="viewLoAchievementLink"
                           class="btn btn-warning">
                        View LO Achievement Result
                    </a>

                    <button type="submit" class="btn btn-danger" id="saveMarksButton" @(isImpersonated ? "disabled style=\"display:none\"" : "")>
                        Save Marks
                    </button>

                    <button type="submit"
                            form="clearMarksForm"
                            class="btn btn-outline-danger"
                        @(isImpersonated ? "disabled style=\"display:none\"" : "")>
                        Clear Marks
                    </button>
                </div>
            </form>

        </div>
    </div>

</div>

<form id="clearMarksForm" asp-controller="MarkStudents" asp-action="ClearMarks" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="assignmentId" value="@Model.AssignmentId" />
    <input type="hidden" name="studentId" value="@Model.StudentInternalId" />
    <input type="hidden" name="courseCode" value="@Model.CourseCode" />
    <input type="hidden" name="courseTitle" value="@Model.CourseTitle" />
    <input type="hidden" name="assessmentName" value="@Model.AssessmentName" />
    <input type="hidden" name="year" value="@Model.Year" />
    <input type="hidden" name="trimester" value="@Model.Trimester" />
</form>

<style>
    .rubric-marking-table {
        width: 100%;
        table-layout: fixed;
        font-size: 0.82rem;
    }

        .rubric-marking-table th,
        .rubric-marking-table td {
            vertical-align: top;
        padding: 6px;
            word-wrap: break-word;
        }

    .criteria-col {
        width: 22%;
    }

    .weight-col,
    .lo-col,
    .marks-col {
        width: 7%;
    }

    .level-header-col {
        width: 12.8%;
        font-size: 1.15rem;
        font-weight: 600;
    }

    .scale-name-header {
        font-size: 0.82rem;
        font-weight: 500;
    }

    .criterion-text {
        font-size: 0.88rem;
        line-height: 1.25;
    }

    .level-desc-cell {
        padding: 0 !important;
    }

    .rubric-cell-btn {
        width: 100%;
        min-height: 120px;
        border: none;
        background: transparent;
        cursor: pointer;
        padding: 6px;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 0.82rem;
        transition: background-color 0.15s ease;
        margin: 0;
    }

        .rubric-cell-btn:hover {
            background-color: rgba(0,0,0,0.05);
        }

        .rubric-cell-btn.selected {
            background-color: #b32017 !important;
            color: #fff !important;
        }

    .cell-score {
        font-size: 1rem;
        font-weight: 700;
        text-align: center;
    }

    .cell-scale {
        font-size: 0.82rem;
        font-weight: 600;
        text-align: center;
    }

    .cell-description {
        font-size: 0.76rem;
        line-height: 1.2;
        flex: 1;
    }
</style>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const buttons = document.querySelectorAll(".level-btn");
        const selectedLevels = {};
        const form = document.getElementById("saveMarksForm");
        const saveBtn = document.getElementById("saveMarksButton");
        const criteriaCount = document.querySelectorAll(".calculated-marks[data-criterion-id]").length;
        const commentInput = document.getElementById("commentInput");
        const loAchievementLink = document.getElementById("viewLoAchievementLink");
        const hasServerError = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(!string.IsNullOrEmpty(errorMessage)));
        const draftStorageKey = "mark-student-draft:@Model.AssignmentId:@Model.StudentInternalId";

        function updateTotalScore() {
            let total = 0;

            document.querySelectorAll(".calculated-marks").forEach(function (cell) {
                const value = parseFloat(cell.textContent);
                if (!isNaN(value)) {
                    total += value;
                }
            });

            const totalScoreCell = document.getElementById("total-score");
            if (totalScoreCell) {
                totalScoreCell.textContent = total.toFixed(2);
            }
        }

        function updateHiddenJson() {
            const arr = Object.keys(selectedLevels).map(key => ({
                CriterionId: parseInt(key),
                SelectedLevel: selectedLevels[key]
            }));

            const hidden = document.getElementById("selectedLevelsJson");
            if (hidden) {
                hidden.value = JSON.stringify(arr);
            }
        }

        function saveDraft() {
            try {
                sessionStorage.setItem(draftStorageKey, JSON.stringify({
                    selectedLevels: selectedLevels,
                    comment: commentInput ? commentInput.value : ""
                }));
            } catch (error) {
                console.warn("Unable to cache draft marks.", error);
            }
        }

        function clearDraft() {
            try {
                sessionStorage.removeItem(draftStorageKey);
            } catch (error) {
                console.warn("Unable to clear cached draft marks.", error);
            }
        }

        function applySelection(criterionId, selectedLevel) {
            const normalizedCriterionId = String(criterionId);
            const normalizedLevel = Number(selectedLevel);

            if (Number.isNaN(normalizedLevel)) {
                return;
            }

            let matchedButton = null;

            document.querySelectorAll(".level-btn").forEach(function (btn) {
                if (btn.getAttribute("data-criterion-id") !== normalizedCriterionId) {
                    return;
                }

                btn.classList.remove("selected");

                if (Number(btn.getAttribute("data-level")) === normalizedLevel) {
                    matchedButton = btn;
                }
            });

            if (!matchedButton) {
                return;
            }

            matchedButton.classList.add("selected");

            const weight = parseFloat(matchedButton.getAttribute("data-weight"));
            const calculated = normalizedLevel * weight;
            const marksCell = document.querySelector(".calculated-marks[data-criterion-id='" + normalizedCriterionId + "']");

            if (marksCell) {
                marksCell.textContent = calculated.toFixed(2);
            }

            selectedLevels[normalizedCriterionId] = normalizedLevel;
        }

        function restoreDraft() {
            if (!hasServerError) {
                clearDraft();
                return;
            }

            try {
                const rawDraft = sessionStorage.getItem(draftStorageKey);
                if (!rawDraft) {
                    return;
                }

                const draft = JSON.parse(rawDraft);
                const draftSelections = draft.selectedLevels || {};

                Object.keys(selectedLevels).forEach(function (key) {
                    delete selectedLevels[key];
                });

                Object.keys(draftSelections).forEach(function (criterionId) {
                    applySelection(criterionId, draftSelections[criterionId]);
                });

                if (commentInput && typeof draft.comment === "string") {
                    commentInput.value = draft.comment;
                }

                updateHiddenJson();
                updateTotalScore();
            } catch (error) {
                console.warn("Unable to restore cached draft marks.", error);
            }
        }

        document.querySelectorAll(".level-btn.selected").forEach(function (btn) {
            const criterionId = btn.getAttribute("data-criterion-id");
            const selectedLevel = parseFloat(btn.getAttribute("data-level"));
            selectedLevels[criterionId] = selectedLevel;
        });

        updateHiddenJson();
        updateTotalScore();
        restoreDraft();

        buttons.forEach(function (button) {
            button.addEventListener("click", function () {
                if (this.disabled) return;

                const criterionId = this.getAttribute("data-criterion-id");
                const selectedLevel = parseFloat(this.getAttribute("data-level"));
                const weight = parseFloat(this.getAttribute("data-weight"));
                const calculated = selectedLevel * weight;

                document.querySelectorAll(".level-btn").forEach(function (btn) {
                    if (btn.getAttribute("data-criterion-id") === criterionId) {
                        btn.classList.remove("selected");
                    }
                });

                this.classList.add("selected");

                const marksCell = document.querySelector(".calculated-marks[data-criterion-id='" + criterionId + "']");
                if (marksCell) {
                    marksCell.textContent = calculated.toFixed(2);
                }

                selectedLevels[criterionId] = selectedLevel;
                updateHiddenJson();
                updateTotalScore();
                saveDraft();
            });
        });

        // Client-side verification on save: warn if any rubric cells are unselected
        if (form && saveBtn) {
            form.addEventListener("submit", function (e) {
                // Only validate when hitting Save Marks, not other hidden forms
                const active = document.activeElement;
                if (active && active !== saveBtn) return;

                const selectedCount = Object.keys(selectedLevels).length;

                if (selectedCount === 0) {
                    alert("Please select rubric levels before saving marks.");
                    e.preventDefault();
                    return;
                }

                if (criteriaCount > 0 && selectedCount < criteriaCount) {
                    const missing = criteriaCount - selectedCount;
                    const ok = confirm(`You still have ${missing} unselected rubric cell(s). Save anyway?`);
                    if (!ok) {
                        e.preventDefault();
                        saveDraft();
                        return;
                    }
                }

                clearDraft();
            });
        }

        if (commentInput) {
            commentInput.addEventListener("input", saveDraft);
        }

        if (loAchievementLink) {
            loAchievementLink.addEventListener("click", saveDraft);
        }
    });
</script>
