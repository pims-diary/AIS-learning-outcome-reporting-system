@{
    ViewData["Title"] = $"Assignment {ViewBag.AssessmentName}";
    Layout = "_DashboardLayout";
}

<link rel="stylesheet" href="~/css/assignment-dashboard.css" />

<div class="assignment-page">

    @await Html.PartialAsync("_PageHeader", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        { "Breadcrumbs", new List<(string Label, string? Controller, string? Action, object? RouteValues)>
            {
                ($"{ViewBag.CourseCode} {ViewBag.Year} - T{ViewBag.Trimester}", "CourseDashboard", "Index", new { courseCode = ViewBag.CourseCode, year = ViewBag.Year, trimester = ViewBag.Trimester }),
                ("Assessments", null, null, null),
                (ViewBag.AssessmentName as string, null, null, null)
            }
        },
        { "BackController",  "CourseDashboard" },
        { "BackAction",      "Index" },
        { "BackRouteValues", new { courseCode = ViewBag.CourseCode, year = ViewBag.Year, trimester = ViewBag.Trimester } as object },
    })

    <!-- Page Title -->
    <h1 class="page-title">@ViewBag.AssessmentName</h1>

    <!-- Cards Grid -->
    <div class="card-grid">

        <a asp-controller="Assignment"
               asp-action="Information"
               asp-route-id="@Model.Id">


            <div class="assignment-card">
                <img src="~/images/AssignmentInformation.png" alt="Assignment Info" />
                <h3>Assignment Information</h3>
                <p>Essential details of the Assessment</p>
            </div>

        </a>

        <a asp-controller="Rubric"
               asp-action="Index"
               asp-route-assignmentId="@Model.Id"
               asp-route-assessmentName="@Model.AssessmentName"
               asp-route-courseCode="@Model.CourseCode"
               asp-route-courseTitle="@Model.CourseTitle"
               asp-route-year="@Model.Year"
               asp-route-trimester="@Model.Trimester"
               class="assignment-card-link">

            <div class="assignment-card">
                <img src="~/images/RubricManagement.png" alt="Rubric" />
                <h3>Rubric Management</h3>
                <p>Upload, Edit, or Create the Rubric</p>
            </div>
        </a>


        <a asp-controller="LOMapping"
               asp-action="Index"
               asp-route-assignmentId="@Model.Id"
               asp-route-assessmentName="@Model.AssessmentName"
               asp-route-courseCode="@Model.CourseCode"
               asp-route-courseTitle="@Model.CourseTitle"
               asp-route-year="@Model.Year"
               asp-route-trimester="@Model.Trimester"
               class="assignment-card-link">

            <div class="assignment-card">
                <img src="~/images/LOMappingAndWeighting.png" alt="LO Mapping" />
                <h3>LO Mapping and Weighting</h3>
                <p>Mapping each criterion to LOs and assigning its weight</p>
            </div>
        </a>

        <a asp-controller="MarkStudents"
               asp-action="Index"
               asp-route-assignmentId="@Model.Id"
               asp-route-courseCode="@Model.CourseCode"
               asp-route-courseTitle="@Model.CourseTitle"
               asp-route-assessmentName="@Model.AssessmentName"
               asp-route-year="@Model.Year"
               asp-route-trimester="@Model.Trimester"
               class="assignment-card-link">

            <div class="assignment-card">
                <img src="~/images/MarkStudents.png" alt="Mark Students" />
                <h3>Mark Students</h3>
                <p>Enter or Update student scores</p>
            </div>

        </a>

    </div>

</div>