@model AIS_LO_System.Models.Reports.StudentCourseLOOverviewViewModel
@using AIS_LO_System.Models

@{
    ViewData["Title"] = "Overall LO Achievement Overview";
    Layout = "_DashboardLayout";
    var studentLoSubmission = ViewBag.Submission as CourseSubmission;
}

<div class="container mt-4">

    @await Html.PartialAsync("_PageHeader", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        { "Breadcrumbs", new List<(string Label, string? Controller, string? Action, object? RouteValues)>
            {
                ($"{Model.CourseCode} {Model.Year} - T{Model.Trimester}", "CourseDashboard", "Index", new { courseCode = Model.CourseCode, year = Model.Year, trimester = Model.Trimester }),
                ("Student LO Report", "StudentLOReport", "Index", new { courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, year = Model.Year, trimester = Model.Trimester }),
                ("Overview", null, null, null)
            }
        },
        { "BackController",  "StudentLOReport" },
        { "BackAction",      "Index" },
        { "BackRouteValues", new { courseCode = Model.CourseCode, courseTitle = Model.CourseTitle, year = Model.Year, trimester = Model.Trimester } as object },
    })

    @if (studentLoSubmission != null)
    {
        @await Component.InvokeAsync("SubmissionStatus", new { submission = studentLoSubmission })
    }

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1">@Model.StudentName</h2>
            <div class="text-muted mb-1"><strong>Student ID:</strong> @Model.StudentId</div>
            <div class="text-muted mb-1"><strong>Course:</strong> @Model.CourseCode @Model.CourseTitle</div>
            <div class="text-muted"><strong>Semester:</strong> @Model.TrimesterLabel</div>
        </div>
    </div>

    <!-- Bar graph -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Overall LO Achievement Overview</h4>

            @if (Model.LOSummaries.Any())
            {
                <div class="chart-box">
                    <div class="y-axis-label top">100</div>
                    <div class="chart-grid">
                        <div class="grid-line line-80"></div>
                        <div class="grid-line line-60"></div>
                        <div class="grid-line line-40"></div>
                        <div class="grid-line line-20"></div>

                        <div class="bars-wrap">
                            @foreach (var lo in Model.LOSummaries)
                            {
                                var barClass = lo.Status == "Achieved"
                                ? "bar-achieved"
                                : "bar-not-achieved";

                                <div class="bar-item">
                                    <div class="bar-percent">@lo.Percentage.ToString("0.##")%</div>
                                    <div class="bar @barClass" style="height:@lo.Percentage%;"></div>
                                    <div class="bar-label">@lo.Label</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="chart-info-box">
                    <div class="chart-info-status">
                        @Model.AchievedCount of @Model.TotalLOCount Learning Outcomes Achieved
                    </div>

                    <div class="legend-inline">
                        <div class="legend-item">
                            <span class="legend-box achieved-box"></span> Achieved
                        </div>
                        <div class="legend-item">
                            <span class="legend-box not-box"></span> Not Achieved
                        </div>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">
                    No graded assessment data is available yet for this student in this course.
                </p>
            }
        </div>
    </div>

    <!-- Analysis -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Learning Outcome Analysis</h4>

            @if (!Model.LOSummaries.Any())
            {
                <p class="text-muted mb-0">
                    No LO analysis is available yet because no assessments have been graded.
                </p>
            }
            else
            {
                @foreach (var item in Model.LOAnalyses)
                {
                    <div class="analysis-block">
                        <div class="analysis-title">
                            @item.Label - @item.Percentage.ToString("0.##")% (@item.Status)
                        </div>

                        <div class="analysis-text mb-2">
                            <strong>@item.Label</strong>: @item.LearningOutcomeText
                        </div>

                        @foreach (var line in item.AssessmentBreakdown)
                        {
                            <div class="analysis-text">@line</div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- Contribution Table -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Assessment Contribution to Course Learning Outcomes</h4>

            @if (!Model.LOSummaries.Any() && !Model.Contributions.Any())
            {
                <p class="text-muted mb-0">
                    No contribution data is available yet.
                </p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>Assessment</th>
                                <th>Weight</th>
                                <th>Status</th>
                                <th title="Shows how much this assignment contributes to each learning outcome across the whole course.">
                                    Contribution to Course LO(s)
                                </th>
                                <th title="Shows how well the student performed for that learning outcome within this assignment only.">
                                    Student Performance in Assessment
                                </th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Contributions)
                            {
                                <tr>
                                    <td>@item.AssessmentName</td>

                                    <td>
                                        @(item.AssignmentWeight > 0 ? item.AssignmentWeight + "%" : "Not Set")
                                    </td>

                                    <td>
                                        @if (item.IsGraded)
                                        {
                                            <span class="badge bg-success">@item.StatusText</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@item.StatusText</span>
                                        }
                                    </td>

                                    <td title="@item.ContributionTooltip">
                                        @foreach (var contribution in item.Contributions)
                                        {
                                            <div>@contribution</div>
                                        }
                                    </td>

                                    <td title="@item.AchievementTooltip">
                                        @foreach (var achievement in item.Achievements)
                                        {
                                            <div>@achievement</div>
                                        }
                                    </td>

                                    <td>
                                        @if (item.IsGraded)
                                        {
                                            <a asp-controller="MarkStudents"
                                                   asp-action="LOAchievementReport"
                                                   asp-route-studentId="@Model.StudentInternalId"
                                                   asp-route-assignmentId="@item.AssignmentId"
                                                   asp-route-courseCode="@Model.CourseCode"
                                                   asp-route-courseTitle="@Model.CourseTitle"
                                                   asp-route-assessmentName="@item.AssessmentName"
                                                   asp-route-year="@Model.Year"
                                                   asp-route-trimester="@Model.Trimester"
                                                   class="btn btn-sm btn-danger">
                                                View Report
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Combined LO Summary -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Combined LO Summary</h4>

            @if (Model.LOSummaries.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>LO</th>
                                <th>Learning Outcome</th>
                                <th>Student Score</th>
                                <th>Maximum Possible Score</th>
                                <th>Student Achievement (%)</th>
                                <th>LO Result</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lo in Model.LOSummaries)
                            {
                                <tr>
                                    <td>@lo.Label</td>
                                    <td>@lo.LearningOutcomeText</td>
                                    <td>@lo.AchievedScore.ToString("0.00")</td>
                                    <td>@lo.MaxScore.ToString("0.00")</td>
                                    <td>@lo.Percentage.ToString("0.##")%</td>
                                    <td>
                                        @if (lo.Status == "Achieved")
                                        {
                                            <span class="badge bg-success">Achieved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Not Achieved</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">
                    No graded assessment data is available yet for this student in this course.
                </p>
            }
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mb-4">
        <a asp-controller="StudentLOReport"
               asp-action="DownloadStudentCourseReportPdf"
               asp-route-studentId="@Model.StudentInternalId"
               asp-route-courseCode="@Model.CourseCode"
               asp-route-courseTitle="@Model.CourseTitle"
               asp-route-year="@Model.Year"
               asp-route-trimester="@Model.Trimester"
               style="background-color:#c21c00;color:white;padding:10px 22px;border-radius:10px;font-size:15px;font-weight:600;border:none;text-decoration:none;display:inline-block;line-height:1.2;white-space:nowrap;">
            Download PDF
        </a>
    </div>

</div>

<style>
    .chart-box {
        position: relative;
        padding-left: 34px;
        padding-top: 18px;
    }

    .y-axis-label.top {
        position: absolute;
        left: 0;
        top: 0;
        font-size: 0.95rem;
        color: #c62828;
        font-weight: 700;
    }

    .chart-grid {
        position: relative;
        height: 340px;
        border-left: 2px solid #555;
        border-bottom: 2px solid #555;
        margin-top: 10px;
    }

    .grid-line {
        position: absolute;
        left: 0;
        right: 0;
        border-top: 1px solid #bbb;
    }

    .line-80 {
        top: 20%;
    }

    .line-60 {
        top: 40%;
    }

    .line-40 {
        top: 60%;
    }

    .line-20 {
        top: 80%;
    }

    .bars-wrap {
        position: absolute;
        left: 30px;
        right: 30px;
        bottom: 0;
        top: 0;
        display: flex;
        justify-content: space-around;
        align-items: flex-end;
        padding-bottom: 36px;
    }

    .bar-item {
        width: 90px;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        align-items: center;
    }

    .bar {
        width: 40px;
        min-height: 2px;
        border: 1px solid #555;
    }

    .bar-percent {
        font-size: 1rem;
        color: #c62828;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .bar-label {
        margin-top: 8px;
        font-size: 0.95rem;
        color: #c62828;
        font-weight: 600;
    }

    .bar-achieved {
        background: green;
    }

    .bar-not-achieved {
        background: red;
    }

    .chart-info-box {
        margin-top: 16px;
        padding: 12px 14px;
        background: #fafafa;
        border: 1px solid #e1e1e1;
        border-radius: 6px;
        font-size: 0.92rem;
    }

    .chart-info-status {
        font-weight: 700;
        color: #b32017;
        margin-bottom: 8px;
    }

    .legend-inline {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

    .legend-item {
        font-size: 0.9rem;
    }

    .legend-box {
        display: inline-block;
        width: 12px;
        height: 12px;
        margin-right: 8px;
    }

    .achieved-box {
        background: green;
    }

    .not-box {
        background: red;
    }

    .analysis-block {
        padding: 12px 0;
        border-bottom: 1px solid #ececec;
    }

        .analysis-block:last-child {
            border-bottom: none;
        }

    .analysis-title {
        font-weight: 700;
        color: #b32017;
        margin-bottom: 6px;
    }

    .analysis-text {
        font-size: 0.95rem;
        color: #333;
    }
</style>