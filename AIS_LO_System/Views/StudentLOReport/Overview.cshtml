@model AIS_LO_System.Models.Reports.StudentCourseLOOverviewViewModel

@{
    ViewData["Title"] = "Overall LO Achievement Overview";
    Layout = "_DashboardLayout";
}

<div class="container mt-4">

    <!-- Breadcrumb -->
    <div class="breadcrumb mb-3">
        <a class="crumb-link"
           asp-controller="CourseDashboard"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            @Model.CourseCode @Model.CourseTitle
        </a>

        <span>/</span>

        <a class="crumb-link"
           asp-controller="StudentLOReport"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            Student LO Report
        </a>

        <span>/</span>

        <span>Overall LO Achievement Overview</span>
    </div>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1">@Model.StudentName</h2>
            <div class="text-muted mb-1"><strong>Student ID:</strong> @Model.StudentId</div>
            <div class="text-muted mb-1"><strong>Course:</strong> @Model.CourseCode @Model.CourseTitle</div>
            <div class="text-muted"><strong>Semester:</strong> @Model.TrimesterLabel</div>
        </div>

        <a asp-controller="StudentLOReport"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester"
           class="btn btn-outline-secondary">
            ← Go Back
        </a>
    </div>

    <!-- Placeholder card for next part -->
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Overall LO Achievement Overview</h4>
            <p class="text-muted mb-0">
                This report page has been created successfully. In the next part, we will add:
                bar graph, LO analysis, and contribution table.
            </p>
        </div>
    </div>
</div>