@model AIS_LO_System.Models.Reports.StudentCourseLOOverviewViewModel

@{
    ViewData["Title"] = "Overall LO Achievement Overview";
    Layout = "_DashboardLayout";
}

<div class="container mt-4">

    <div class="breadcrumb mb-3">
        <a class="crumb-link"
           asp-controller="CourseDashboard"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            @Model.CourseCode @Model.CourseTitle
        </a>

        <span>/</span>

        <a class="crumb-link"
           asp-controller="StudentLOReport"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester">
            Student LO Report
        </a>

        <span>/</span>

        <span>Overall LO Achievement Overview</span>
    </div>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1">@Model.StudentName</h2>
            <div class="text-muted mb-1"><strong>Student ID:</strong> @Model.StudentId</div>
            <div class="text-muted mb-1"><strong>Course:</strong> @Model.CourseCode @Model.CourseTitle</div>
            <div class="text-muted"><strong>Semester:</strong> @Model.TrimesterLabel</div>
        </div>

        <a asp-controller="StudentLOReport"
           asp-action="Index"
           asp-route-courseCode="@Model.CourseCode"
           asp-route-courseTitle="@Model.CourseTitle"
           asp-route-year="@Model.Year"
           asp-route-trimester="@Model.Trimester"
           class="btn btn-outline-secondary">
            ← Go Back
        </a>
    </div>

    <!-- Assessment status -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Assessment Status</h4>

            @if (Model.Assessments.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 60%;">Assessment</th>
                                <th style="width: 40%;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var assessment in Model.Assessments)
                            {
                                <tr>
                                    <td>@assessment.AssessmentName</td>
                                    <td>
                                        @if (assessment.IsGraded)
                                        {
                                            <span class="badge bg-success">Graded</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Not Graded</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No assessments found for this course yet.</p>
            }
        </div>
    </div>

    <!-- LO summary check -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Combined LO Summary</h4>

            @if (Model.LOSummaries.Any())
            {
                <div class="mb-3 text-muted">
                    <strong>Achieved:</strong> @Model.AchievedCount /
                    <strong>Not Achieved:</strong> @Model.NotAchievedCount /
                    <strong>Total:</strong> @Model.TotalLOCount
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>LO</th>
                                <th>Learning Outcome</th>
                                <th>Achieved Score</th>
                                <th>Max Score</th>
                                <th>Percentage</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lo in Model.LOSummaries)
                            {
                                <tr>
                                    <td>@lo.Label</td>
                                    <td>@lo.LearningOutcomeText</td>
                                    <td>@lo.AchievedScore.ToString("0.00")</td>
                                    <td>@lo.MaxScore.ToString("0.00")</td>
                                    <td>@lo.Percentage.ToString("0.##")%</td>
                                    <td>
                                        @if (lo.Status == "Achieved")
                                        {
                                            <span class="badge bg-success">Achieved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Not Achieved</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">
                    No graded assessment data is available yet for this student in this course.
                </p>
            }
        </div>
    </div>

    <!-- Placeholder -->
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Next Part</h4>
            <p class="text-muted mb-0">
                In the next part, we will convert this combined LO summary into the bar graph section.
            </p>
        </div>
    </div>
</div>