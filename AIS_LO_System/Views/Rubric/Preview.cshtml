@model AIS_LO_System.Models.Rubric

@{
    ViewData["Title"] = "Rubric Preview";
    Layout = "_DashboardLayout";
}

@await Html.PartialAsync("_PageHeader", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        { "Breadcrumbs", new List<(string Label, string? Controller, string? Action, object? RouteValues)>
            {
                ($"{ViewBag.CourseCode} {ViewBag.Year} - T{ViewBag.Trimester}", "CourseDashboard", "Index", new { courseCode = ViewBag.CourseCode, year = ViewBag.Year, trimester = ViewBag.Trimester }),
                (ViewBag.AssessmentName as string, "Assignment", "Index", new { assessmentName = ViewBag.AssessmentName, courseCode = ViewBag.CourseCode, courseTitle = ViewBag.CourseTitle, year = ViewBag.Year, trimester = ViewBag.Trimester }),
                ("Rubric Management", "Rubric", "Index", new { assignmentId = ViewBag.AssignmentId, assessmentName = ViewBag.AssessmentName, courseCode = ViewBag.CourseCode, courseTitle = ViewBag.CourseTitle, year = ViewBag.Year, trimester = ViewBag.Trimester }),
                ("Rubric Preview", null, null, null)
            }
        },
        { "BackController",  "Rubric" },
        { "BackAction",      "Index" },
        { "BackRouteValues", new { assignmentId = Model.AssignmentId } as object },
    })

<h2>Rubric Preview</h2>

<hr />

<a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-warning">
    Edit Rubric
</a>

@if (Model != null && Model.Criteria.Any())
{
    var scaleHeaders = Model.Criteria
        .First()
        .Levels
        .OrderByDescending(l => l.Score)
        .ToList();

    <div class="rubric-table">
        <table>
            <thead>
                <tr>
                    <th>Criteria</th>

                    @foreach (var level in scaleHeaders)
                    {
                        <th>
                            Score @level.Score <br />
                            <span class="scale-header">
                                @level.ScaleName
                            </span>
                        </th>
                    }
                </tr>
            </thead>

            <tbody>
                @foreach (var criterion in Model.Criteria)
                {
                    <tr>
                        <td class="criteria-cell">
                            @criterion.CriterionName
                        </td>

                        @foreach (var level in criterion.Levels
                       .OrderByDescending(l => l.Score))
                        {
                            <td>
                                @level.Description
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<br />