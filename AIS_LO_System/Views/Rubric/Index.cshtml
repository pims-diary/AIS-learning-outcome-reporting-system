@model AIS_LO_System.Models.Rubric
@using System.Linq

@{
    ViewData["Title"] = "Rubric Management";
    Layout = "_DashboardLayout";
}

<link rel="stylesheet" href="~/css/rubric.css" />

<div class="rubric-page">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a asp-controller="CourseDashboard"
               asp-action="Index"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester">
            @ViewBag.CourseCode @($"{ViewBag.Year}-S{ViewBag.Trimester}")
        </a>

        <span>/</span>

        <a asp-controller="Assignment"
               asp-action="Index"
               asp-route-assessmentName="@ViewBag.AssessmentName"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-courseTitle="@ViewBag.CourseTitle"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester">
            Assessments
        </a>

        <span>/</span>
        <span>@ViewBag.AssessmentName</span>
        <span>/</span>
        <span class="active">Rubric Management</span>
    </div>

    <!-- Header -->
    <div class="header-row">
        <h1>Rubric Management</h1>

        <a asp-controller="Assignment"
               asp-action="Index"
               asp-route-assessmentName="@ViewBag.AssessmentName"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-courseTitle="@ViewBag.CourseTitle"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester"
               class="go-back">
            ← Go Back
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background:#d4edda; border:1px solid #c3e6cb; color:#155724; padding:12px 16px; border-radius:8px; margin-bottom:16px;">
            ✅ @TempData["Success"]
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div style="background:#cfe2ff; border:1px solid #b6d4fe; color:#084298; padding:12px 16px; border-radius:8px; margin-bottom:16px;">
            @TempData["Info"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background:#f8d7da; border:1px solid #f5c6cb; color:#721c24; padding:12px 16px; border-radius:8px; margin-bottom:16px;">
            ❌ @TempData["Error"]
        </div>
    }

    @await Component.InvokeAsync("SubmissionStatus", new { submission = ViewBag.Submission as AIS_LO_System.Models.CourseSubmission })

    <!-- Format Guide -->
    <details style="margin-bottom:20px; background:#f0f4ff; border:1px solid #b6d4fe; border-radius:8px; padding:4px 16px;">
        <summary style="cursor:pointer; font-weight:600; color:#084298; padding:10px 0; font-size:14px;">
            Format Guide: How the system reads your rubric
        </summary>
        <div style="font-size:13px; color:#333; line-height:1.7; padding-bottom:12px;">
            <p style="margin:8px 0;"><strong>Supported format:</strong> Excel rubric file</p>

            <p style="margin:12px 0 4px; font-weight:600;">Expected worksheet layout:</p>
            <ul style="margin:4px 0 8px 20px; padding:0;">
                <li>The system searches workbook sheets for a rubric header row instead of relying only on fixed column letters</li>
                <li>The header row should contain <strong>Criteria</strong>, score columns <strong>4, 3, 2, 1, 0</strong>, and optionally <strong>LO</strong> and <strong>Weight (%)</strong></li>
                <li>The row directly under the score headers is used as the scale-name row, for example <strong>Excellent</strong>, <strong>Good</strong>, <strong>Satisfactory</strong>, <strong>Limited</strong>, <strong>Unsatisfactory</strong></li>
                <li>The rows after that are read as the actual rubric criteria rows</li>
                <li>The column with <strong>Criteria</strong> is used as the criterion-name column</li>
                <li>The columns with score headers <strong>4, 3, 2, 1, 0</strong> are used for the level descriptions</li>
                <li>The column with <strong>LO</strong> is used for Learning Outcomes (optional), for example <code>1,2,5</code> or <code>LO1, LO2, LO5</code></li>
                <li>The column with <strong>Weight</strong> is used for the weight percentage (optional), for example <code>10</code>, <code>10.5</code>, or <code>10%</code></li>
            </ul>

            <p style="margin:12px 0 4px; font-weight:600;">LO mapping rules:</p>
            <ul style="margin:4px 0 8px 20px; padding:0;">
                <li>LO numbers are matched against the course Learning Outcomes by their <strong>LO order number</strong></li>
                <li>If the assessment already has selected LOs from the course outline, only those LOs are allowed</li>
                <li>Any rubric LO that is not allowed for this assessment is <strong>skipped</strong> and shown as a warning</li>
            </ul>

            <p style="margin:12px 0 4px; font-weight:600;">Important notes:</p>
            <ul style="margin:4px 0 8px 20px; padding:0;">
                <li>The first worksheet must contain at least one valid criterion row</li>
                <li>If a rubric already exists for this assessment, uploading a new rubric will <strong>replace</strong> the old one</li>
                <li>After upload, the rubric is submitted to the moderator for approval</li>
            </ul>

            <p style="margin:8px 0; color:#555;"><em>Tip: Keep one criterion per row, make sure the rubric sheet includes clear headers, and use clear LO numbers for the most reliable auto-mapping.</em></p>
        </div>
    </details>

    <!-- Action Buttons -->
    @if (string.IsNullOrEmpty(User.FindFirst("ImpersonatedBy")?.Value))
    {
        <div class="action-buttons">

            <!-- Upload -->
            <form asp-action="UploadRubricExcel"
                  method="post"
                  enctype="multipart/form-data">

                <input type="hidden" name="assignmentId" value="@ViewBag.AssignmentId" />
                <input type="hidden" name="assessmentName" value="@ViewBag.AssessmentName" />
                <input type="hidden" name="courseCode" value="@ViewBag.CourseCode" />
                <input type="hidden" name="courseTitle" value="@ViewBag.CourseTitle" />
                <input type="hidden" name="year" value="@ViewBag.Year" />
                <input type="hidden" name="trimester" value="@ViewBag.Trimester" />

                <label class="upload-btn">
                    Upload Rubric
                    <input type="file" name="file" hidden onchange="this.form.submit()" />
                </label>
            </form>

            @if (Model != null)
            {
                <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="red-btn">
                    Edit Rubric
                </a>
            }
        </div>
    }

    <!-- Preview Section -->
    @if (Model != null && Model.Criteria != null && Model.Criteria.Count > 0)
    {
        <h2 class="preview-title">Rubric Preview</h2>

        <div class="rubric-table">
            <table>
                <thead>
                    <tr>
                        <th rowspan="2">Criterion</th>
                        <th colspan="5">Scale (0-4)</th>
                    </tr>
                    <tr>
                        @{
                            // Get scale names from the first criterion's levels
                            var headerLevels = Model.Criteria.First().Levels.OrderByDescending(l => l.Score).ToList();
                        }
                        @foreach (var level in headerLevels)
                        {
                            <th>@level.ScaleName (@level.Score)</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Criteria)
                    {
                        <tr>
                            <td><strong>@c.CriterionName</strong></td>

                            @{
                                var orderedLevels = c.Levels.OrderByDescending(l => l.Score).ToList();
                            }

                            @foreach (var level in orderedLevels)
                            {
                                <td>@level.Description</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align:center; padding:40px 20px; color:#888; font-size:15px;">
            <p style="font-size:40px; margin-bottom:12px;">📄</p>
            <p>No rubric uploaded yet. Use the <strong>Upload Rubric</strong> button above to get started.</p>
        </div>
    }

</div>
