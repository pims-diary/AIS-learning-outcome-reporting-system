@model AIS_LO_System.Models.Rubric
@using System.Linq

@{
    ViewData["Title"] = "Rubric Management";
    Layout = "_DashboardLayout";
}

<link rel="stylesheet" href="~/css/rubric.css" />

<div class="rubric-page">

    @await Html.PartialAsync("_PageHeader", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        { "Breadcrumbs", new List<(string Label, string? Controller, string? Action, object? RouteValues)>
            {
                ($"{ViewBag.CourseCode} {ViewBag.Year} - T{ViewBag.Trimester}", "CourseDashboard", "Index", new { courseCode = ViewBag.CourseCode, year = ViewBag.Year, trimester = ViewBag.Trimester }),
                (ViewBag.AssessmentName as string, "Assignment", "Index", new { assessmentName = ViewBag.AssessmentName, courseCode = ViewBag.CourseCode, courseTitle = ViewBag.CourseTitle, year = ViewBag.Year, trimester = ViewBag.Trimester }),
                ("Rubric Management", null, null, null)
            }
        },
        { "BackController",  "Assignment" },
        { "BackAction",      "Index" },
        { "BackRouteValues", new { assessmentName = ViewBag.AssessmentName, courseCode = ViewBag.CourseCode, courseTitle = ViewBag.CourseTitle, year = ViewBag.Year, trimester = ViewBag.Trimester } as object },
    })

    @{
        var hasSuccess = TempData["Success"] != null;
        var hasInfo = TempData["Info"] != null;
        var hasWarning = TempData["Warning"] != null;
        var hasError = TempData["Error"] != null;
        var hasAnyNotification = hasSuccess || hasInfo || hasWarning || hasError;
    }

    @if (hasAnyNotification)
    {
        <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:16px;">
            @if (hasSuccess)
            {
                <div style="background:#d4edda; border:1px solid #c3e6cb; color:#155724; padding:12px 16px; border-radius:8px;">
                    @TempData["Success"]
                </div>
            }
            @if (hasInfo)
            {
                <div style="background:#cfe2ff; border:1px solid #b6d4fe; color:#084298; padding:12px 16px; border-radius:8px;">
                    @TempData["Info"]
                </div>
            }
            @if (hasWarning)
            {
                <div style="background:#fff3cd; border:1px solid #ffc107; color:#856404; padding:12px 16px; border-radius:8px;">
                    @TempData["Warning"]
                </div>
            }
            @if (hasError)
            {
                <div style="background:#f8d7da; border:1px solid #f5c6cb; color:#721c24; padding:12px 16px; border-radius:8px;">
                    @TempData["Error"]
                </div>
            }
        </div>
    }

    @await Component.InvokeAsync("SubmissionStatus", new { submission = ViewBag.Submission as AIS_LO_System.Models.CourseSubmission })

    @{
        bool hasRubric = Model != null && Model.Criteria != null && Model.Criteria.Count > 0;
    }

    @if (!hasRubric)
    {
        @await Html.PartialAsync("_RubricFormatGuide")
    }

    <!-- Action Buttons -->
    @if (string.IsNullOrEmpty(User.FindFirst("ImpersonatedBy")?.Value))
    {
        <div class="action-buttons">

            <!-- Upload -->
            <form asp-action="UploadRubricExcel"
                  method="post"
                  enctype="multipart/form-data">

                <input type="hidden" name="assignmentId" value="@ViewBag.AssignmentId" />
                <input type="hidden" name="assessmentName" value="@ViewBag.AssessmentName" />
                <input type="hidden" name="courseCode" value="@ViewBag.CourseCode" />
                <input type="hidden" name="courseTitle" value="@ViewBag.CourseTitle" />
                <input type="hidden" name="year" value="@ViewBag.Year" />
                <input type="hidden" name="trimester" value="@ViewBag.Trimester" />

                <label class="upload-btn">
                    Upload Rubric
                    <input type="file" name="file" hidden onchange="this.form.submit()" />
                </label>
            </form>

            @if (Model != null)
            {
                <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="red-btn">
                    Edit Rubric
                </a>
            }
        </div>
    }

    <!-- Preview Section -->
    @if (Model != null && Model.Criteria != null && Model.Criteria.Count > 0)
    {
        <h2 class="preview-title">Rubric Preview</h2>

        <div class="rubric-table">
            <table>
                <thead>
                    <tr>
                        <th rowspan="2">Criterion</th>
                        <th colspan="5">Scale (0-4)</th>
                    </tr>
                    <tr>
                        @{
                            // Get scale names from the first criterion's levels
                            var headerLevels = Model.Criteria.First().Levels.OrderByDescending(l => l.Score).ToList();
                        }
                        @foreach (var level in headerLevels)
                        {
                            <th>@level.ScaleName (@level.Score)</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Criteria)
                    {
                        <tr>
                            <td><strong>@c.CriterionName</strong></td>

                            @{
                                var orderedLevels = c.Levels.OrderByDescending(l => l.Score).ToList();
                            }

                            @foreach (var level in orderedLevels)
                            {
                                <td>@level.Description</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="text-align:center; padding:40px 20px; color:#888; font-size:15px;">
            <p style="font-size:40px; margin-bottom:12px;">📄</p>
            <p>No rubric uploaded yet. Use the <strong>Upload Rubric</strong> button above to get started.</p>
        </div>
    }

    @if (hasRubric)
    {
        @await Html.PartialAsync("_RubricFormatGuide")
    }

</div>