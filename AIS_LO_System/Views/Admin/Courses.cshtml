@model List<AIS_LO_System.Models.Course>
@using AIS_LO_System.Controllers

@{
    ViewData["Title"] = "Courses";
    Layout = "_AdminLayout";
    var lecturers = ViewBag.Lecturers as List<AIS_LO_System.Models.AppUser> ?? new();
    var moderators = ViewBag.Moderators as List<AIS_LO_System.Models.AppUser> ?? new();
}


<div class="admin-content">
    <div class="admin-panel">

        <div class="admin-panel-header">
            <div class="admin-panel-title">Courses</div>
            <button class="btn-admin-add" onclick="openModal('addCourseModal')">Add Course</button>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="admin-alert admin-alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="admin-alert admin-alert-error">@TempData["Error"]</div>
        }

        <div class="admin-toolbar">
            <form method="get" class="admin-search-form">
                <input name="search" class="admin-search-input" placeholder="Search by course code..."
                       value="@Context.Request.Query["search"]" />
                <select name="trimester" class="admin-filter-select" onchange="this.form.submit()">
                    <option value="all">All Trimesters</option>
                    @foreach (var t in (IEnumerable<TrimesterOption>)ViewBag.Trimesters)
                    {
                        var val = $"{t.Year}-{t.Trimester}";
                        var label = $"{t.Year} T{t.Trimester}";
                        <option value="@val" selected="@(Context.Request.Query["trimester"] == val)">@label</option>
                    }
                </select>
            </form>

            <div class="admin-status-tabs">
                <a href="?status=all" class="status-tab @(ViewBag.Status == "all" ? "status-tab-active" : "")">All</a>
                <a href="?status=active" class="status-tab @(ViewBag.Status == "active" ? "status-tab-active" : "")">Active</a>
                <a href="?status=inactive" class="status-tab @(ViewBag.Status == "inactive" ? "status-tab-active" : "")">Inactive</a>
            </div>

            <form asp-action="ImportCourses" method="post" enctype="multipart/form-data" style="display:inline">
                @Html.AntiForgeryToken()
                <label class="btn-admin-import">
                    Import CSV
                    <input type="file" name="file" accept=".csv" style="display:none" onchange="this.form.submit()" />
                </label>
            </form>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Course Code</th>
                    <th>Trimester</th>
                    <th>Status</th>
                    <th>Lecturer/s</th>
                    <th>Moderator</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="admin-empty">No Courses Added Yet</td>
                    </tr>
                }
                else
                {
                    @foreach (var c in Model)
                    {
                        bool isActive = c.Year == ViewBag.CurrentYear && c.Trimester == ViewBag.CurrentTrimester;
                        <tr class="@(!isActive ? "row-inactive" : "")">
                            <td class="admin-td-code">@c.Code</td>
                            <td>@c.Year T@(c.Trimester)</td>
                            <td>
                                <span class="status-pill @(isActive ? "status-active" : "status-inactive")">
                                    @(isActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                @if (c.Lecturer != null)
                                {
                                    <span class="role-pill-lecturer">@c.Lecturer.FullName</span>
                                }
                                else
                                {
                                    <span class="role-pill-unassigned">Unassigned</span>
                                }
                            </td>
                            <td>
                                @if (c.Moderator != null)
                                {
                                    <span class="role-pill-moderator">@c.Moderator.FullName</span>
                                }
                                else
                                {
                                    <span class="role-pill-unassigned">Unassigned</span>
                                }
                            </td>
                            <td class="admin-td-actions">
                                <button class="btn-admin-edit"
                                        onclick="openEditCourse(@c.Id, '@c.Title', '@c.School', @(c.LecturerId?.ToString() ?? "null"), @(c.ModeratorId?.ToString() ?? "null"))">
                                    Edit
                                </button>
                                <form asp-action="RemoveCourse" method="post" style="display:inline"
                                      onsubmit="return confirm('Remove @c.Code?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <button type="submit" class="btn-admin-remove">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Course Modal -->
<div class="admin-modal-bg" id="addCourseModal">
    <div class="admin-modal">
        <div class="admin-modal-title">Add Course</div>
        <form asp-action="AddCourse" method="post">
            @Html.AntiForgeryToken()
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Course Code *</label>
                    <input name="code" class="admin-input" placeholder="e.g. COMP720" required />
                </div>
                <div class="admin-form-group">
                    <label>Course Title *</label>
                    <input name="title" class="admin-input" placeholder="e.g. IT Project" required />
                </div>
            </div>
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Year *</label>
                    <input name="year" type="number" class="admin-input" value="@DateTime.Now.Year" required />
                </div>
                <div class="admin-form-group">
                    <label>Trimester *</label>
                    <select name="trimester" class="admin-input">
                        <option value="1">T1</option>
                        <option value="2">T2</option>
                        <option value="3">T3</option>
                    </select>
                </div>
                <div class="admin-form-group">
                    <label>School</label>
                    <input name="school" class="admin-input" placeholder="Information Technology" />
                </div>
            </div>
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Assign Lecturer</label>
                    <select name="lecturerId" class="admin-input">
                        <option value="">Unassigned</option>
                        @foreach (var l in lecturers)
                        {
                            <option value="@l.Id">@l.FullName</option>
                        }
                    </select>
                </div>
                <div class="admin-form-group">
                    <label>Assign Moderator</label>
                    <select name="moderatorId" class="admin-input">
                        <option value="">Unassigned</option>
                        @foreach (var m in moderators)
                        {
                            <option value="@m.Id">@m.FullName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="button" class="btn-admin-cancel" onclick="closeModal('addCourseModal')">Cancel</button>
                <button type="submit" class="btn-admin-save">Add Course</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Course Modal -->
<div class="admin-modal-bg" id="editCourseModal">
    <div class="admin-modal">
        <div class="admin-modal-title">Edit Course</div>
        <form asp-action="EditCourse" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editCourseId" />
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Course Title *</label>
                    <input name="title" id="editCourseTitle" class="admin-input" required />
                </div>
                <div class="admin-form-group">
                    <label>School</label>
                    <input name="school" id="editCourseSchool" class="admin-input" />
                </div>
            </div>
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Lecturer</label>
                    <select name="lecturerId" id="editCourseLecturer" class="admin-input">
                        <option value="">Unassigned</option>
                        @foreach (var l in lecturers)
                        {
                            <option value="@l.Id">@l.FullName</option>
                        }
                    </select>
                </div>
                <div class="admin-form-group">
                    <label>Moderator</label>
                    <select name="moderatorId" id="editCourseModerator" class="admin-input">
                        <option value="">Unassigned</option>
                        @foreach (var m in moderators)
                        {
                            <option value="@m.Id">@m.FullName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="button" class="btn-admin-cancel" onclick="closeModal('editCourseModal')">Cancel</button>
                <button type="submit" class="btn-admin-save">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }
        function openEditCourse(id, title, school, lecId, modId) {
            document.getElementById('editCourseId').value = id;
            document.getElementById('editCourseTitle').value = title;
            document.getElementById('editCourseSchool').value = school;
            document.getElementById('editCourseLecturer').value = lecId || '';
            document.getElementById('editCourseModerator').value = modId || '';
            openModal('editCourseModal');
        }
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') document.querySelectorAll('.admin-modal-bg.open').forEach(m => m.classList.remove('open'));
        });
    </script>
}