@model List<AIS_LO_System.Models.Student>

@{
    ViewData["Title"] = "Students";
    Layout = "_AdminLayout";
    var courses = ViewBag.Courses as List<AIS_LO_System.Models.Course> ?? new();
}


<div class="admin-content">
    <div class="admin-panel">

        <div class="admin-panel-header">
            <div class="admin-panel-title">Students</div>
            <button class="btn-admin-add" onclick="openModal('addStudentModal')">Add Student</button>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="admin-alert admin-alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="admin-alert admin-alert-error">@TempData["Error"]</div>
        }

        <div class="admin-toolbar">
            <form method="get" class="admin-search-form">
                <input name="search" class="admin-search-input" placeholder="Search by ID or name..."
                       value="@Context.Request.Query["search"]" />
                <select name="courseId" class="admin-filter-select" onchange="this.form.submit()">
                    <option value="">All Courses</option>
                    @foreach (var c in courses)
                    {
                        <option value="@c.Id" selected="@(Context.Request.Query["courseId"] == c.Id.ToString())">
                            @c.Code — @c.Year T@c.Trimester
                        </option>
                    }
                </select>
            </form>

            <div class="admin-status-tabs">
                @{
                    var _sSearch = Context.Request.Query["search"].ToString();
                    var _sCourseId = Context.Request.Query["courseId"].ToString();
                    string STab(string s) => "?" + string.Join("&", new[] {
                        string.IsNullOrEmpty(_sSearch)   ? null : $"search={Uri.EscapeDataString(_sSearch)}",
                        string.IsNullOrEmpty(_sCourseId) ? null : $"courseId={Uri.EscapeDataString(_sCourseId)}",
                        $"status={s}"
                    }.Where(x => x != null));
                }
                <a href="@STab("all")" class="status-tab @(ViewBag.Status == "all" ? "status-tab-active" : "")">All</a>
                <a href="@STab("active")" class="status-tab @(ViewBag.Status == "active" ? "status-tab-active" : "")">Active</a>
                <a href="@STab("inactive")" class="status-tab @(ViewBag.Status == "inactive" ? "status-tab-active" : "")">Inactive</a>
            </div>

            <form asp-action="ImportStudents" method="post" enctype="multipart/form-data" style="display:inline">
                @Html.AntiForgeryToken()
                <label class="btn-admin-import">
                    Import CSV
                    <input type="file" name="file" accept=".csv" style="display:none" onchange="this.form.submit()" />
                </label>
            </form>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Student ID</th>
                    <th>Full Name</th>
                    <th>Programme</th>
                    <th>Status</th>
                    <th>Enrolled In</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="admin-empty">No Student Added Yet</td>
                    </tr>
                }
                else
                {
                    @foreach (var s in Model)
                    {
                        <tr class="@(s.Status == AIS_LO_System.Models.StudentStatus.Inactive ? "row-inactive" : "")">
                            <td>@s.StudentId</td>
                            <td>@s.FullName</td>
                            <td class="text-muted">@(string.IsNullOrEmpty(s.Programme) ? "—" : s.Programme)</td>
                            <td>
                                <span class="status-pill @(s.Status == AIS_LO_System.Models.StudentStatus.Active ? "status-active" : "status-inactive")"
                                      title="@(s.StatusReason ?? "")">
                                    @s.Status
                                </span>
                            </td>
                            <td>
                                @foreach (var e in s.CourseEnrolments.OrderByDescending(e => e.Course.Year).ThenBy(e => e.Course.Trimester))
                                {
                                    <a href="javascript:void(0)"
                                       class="enrol-tag @(e.Course.Year == ViewBag.CurrentYear ? "enrol-tag-current" : "enrol-tag-past")"
                                       title="View @s.FullName's records in @e.Course.Code"
                                       onclick="openStudentReportsModal(@s.Id, '@e.Course.Code', @e.Course.Year, @e.Course.Trimester, '@s.FullName')">
                                        @e.Course.Code <span class="enrol-tag-year">@(e.Course.Year) T@(e.Course.Trimester)</span>
                                    </a>
                                }
                            </td>
                            <td class="admin-td-actions">
                                <button class="btn-admin-edit"
                                        data-id="@s.Id"
                                        data-name="@s.FullName"
                                        data-programme="@(s.Programme ?? "")"
                                        data-status="@s.Status"
                                        data-reason="@(s.StatusReason ?? "")"
                                        data-courses="@string.Join(",", s.CourseEnrolments.Select(e => e.CourseId))"
                                        onclick="openEditStudent(this)">
                                    Edit
                                </button>
                                <form asp-action="RemoveStudent" method="post" style="display:inline"
                                      onsubmit="return confirm('Remove @s.FullName?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit" class="btn-admin-remove">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Student Modal -->
<div class="admin-modal-bg" id="addStudentModal">
    <div class="admin-modal">
        <div class="admin-modal-title">Add Student</div>
        <form asp-action="AddStudent" method="post">
            @Html.AntiForgeryToken()
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Student ID *</label>
                    <input name="studentId" class="admin-input" placeholder="e.g. 2026006" required />
                </div>
                <div class="admin-form-group">
                    <label>Full Name *</label>
                    <input name="fullName" class="admin-input" placeholder="e.g. Maria Santos" required />
                </div>
            </div>
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Programme/Degree</label>
                    <input name="programme" class="admin-input" placeholder="e.g. BIT, GDIT" />
                </div>
                <div class="admin-form-group">
                    <label>Status *</label>
                    <select name="status" class="admin-input" required>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="admin-form-group">
                <label>Status Reason (if Inactive)</label>
                <textarea name="statusReason" class="admin-input" placeholder="e.g. Fees pending, withdrawal, attendance..." style="resize:vertical;min-height:60px;"></textarea>
            </div>
            <div class="admin-form-group">
                <label>Enrol in Course/s</label>
                
                <!-- Filter Controls -->
                <div class="course-filter-controls">
                    <div class="course-filter-row">
                        <select id="addYearFilter" class="admin-input" onchange="filterAddCourses()">
                            <option value="">All Years</option>
                            @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                        <select id="addDeptFilter" class="admin-input" onchange="filterAddCourses()">
                            <option value="">All Departments</option>
                            @foreach (var dept in courses.Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <option value="@dept">@dept</option>
                            }
                        </select>
                    </div>
                    <input type="text" id="addCourseSearch" class="course-search-input" placeholder="Search course code or title..." onkeyup="filterAddCourses()" />
                </div>

                <!-- Accordion Courses -->
                <div class="course-accordion-wrapper">
                    @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                    {
                        <div class="course-year-group">
                            <div class="course-year-label">@year</div>
                            @foreach (var dept in courses.Where(c => c.Year == year).Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <div class="course-dept-group" data-year="@year" data-dept="@dept">
                                    <div class="course-dept-label" onclick="toggleAddDept(this)">
                                        <span class="dept-toggle">▼</span> @dept
                                    </div>
                                    <div class="dept-courses">
                                        @foreach (var c in courses.Where(c => c.Year == year && c.School == dept).OrderBy(c => c.Trimester).ThenBy(c => c.Code))
                                        {
                                            <label class="admin-checkbox-item" data-year="@c.Year" data-dept="@c.School" data-code="@c.Code" data-title="@c.Title.ToLower()">
                                                <input type="checkbox" name="courseIds" value="@c.Id" />
                                                @c.Code — @c.Title <span class="course-tri-tag">T@(c.Trimester)</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="button" class="btn-admin-cancel" onclick="closeModal('addStudentModal')">Cancel</button>
                <button type="submit" class="btn-admin-save">Add Student</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Student Modal -->
<div class="admin-modal-bg" id="editStudentModal">
    <div class="admin-modal">
        <div class="admin-modal-title">Edit Student</div>
        <form asp-action="EditStudent" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editStudentId" />
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Full Name *</label>
                    <input name="fullName" id="editStudentName" class="admin-input" required />
                </div>
            </div>
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Programme/Degree</label>
                    <input name="programme" id="editStudentProgramme" class="admin-input" placeholder="e.g. BIT, GDIT" />
                </div>
                <div class="admin-form-group">
                    <label>Status *</label>
                    <select name="status" id="editStudentStatus" class="admin-input" required>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="admin-form-group">
                <label>Status Reason (if Inactive)</label>
                <textarea name="statusReason" id="editStudentReason" class="admin-input" placeholder="e.g. Fees pending, withdrawal, attendance..." style="resize:vertical;min-height:60px;"></textarea>
            </div>
            <div class="admin-form-group">
                <label>Enrolled in Course/s</label>
                
                <!-- Filter Controls -->
                <div class="course-filter-controls">
                    <div class="course-filter-row">
                        <select id="editYearFilter" class="admin-input" onchange="filterEditCourses()">
                            <option value="">All Years</option>
                            @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                        <select id="editDeptFilter" class="admin-input" onchange="filterEditCourses()">
                            <option value="">All Departments</option>
                            @foreach (var dept in courses.Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <option value="@dept">@dept</option>
                            }
                        </select>
                    </div>
                    <input type="text" id="editCourseSearch" class="course-search-input" placeholder="Search course code or title..." onkeyup="filterEditCourses()" />
                </div>

                <!-- Accordion Courses -->
                <div class="course-accordion-wrapper" id="editStudentCourses">
                    @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                    {
                        <div class="course-year-group">
                            <div class="course-year-label">@year</div>
                            @foreach (var dept in courses.Where(c => c.Year == year).Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <div class="course-dept-group" data-year="@year" data-dept="@dept">
                                    <div class="course-dept-label" onclick="toggleEditDept(this)">
                                        <span class="dept-toggle">▼</span> @dept
                                    </div>
                                    <div class="dept-courses">
                                        @foreach (var c in courses.Where(c => c.Year == year && c.School == dept).OrderBy(c => c.Trimester).ThenBy(c => c.Code))
                                        {
                                            <label class="admin-checkbox-item" data-year="@c.Year" data-dept="@c.School" data-code="@c.Code" data-title="@c.Title.ToLower()">
                                                <input type="checkbox" name="courseIds" value="@c.Id" />
                                                @c.Code — @c.Title <span class="course-tri-tag">T@(c.Trimester)</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="button" class="btn-admin-cancel" onclick="closeModal('editStudentModal')">Cancel</button>
                <button type="submit" class="btn-admin-save">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Student Reports Modal -->
<div class="admin-modal-bg" id="studentReportsModal">
    <div class="admin-modal" style="width:560px;">
        <!-- Header -->
        <div style="display:flex;flex-direction:row;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:24px;">
            <div>
                <div style="font-size:20px;font-weight:700;color:#1a1a1a;margin-bottom:4px;" id="reportsModalTitle">Reports</div>
                <div style="font-size:13px;color:#6b7280;font-weight:500;" id="reportsModalSubtitle"></div>
            </div>
            <button type="button"
                    onclick="closeModal('studentReportsModal')"
                    title="Close"
                    style="flex-shrink:0;background:none;border:1px solid #e5e7eb;border-radius:8px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#9ca3af;font-size:15px;line-height:1;margin-top:2px;">&#x2715;</button>
        </div>

        <!-- Loading -->
        <div id="reportsModalLoading" style="display:flex;align-items:center;justify-content:center;gap:12px;padding:32px 0;color:#6b7280;font-size:14px;">
            <div style="width:20px;height:20px;border:2px solid #e5e7eb;border-top-color:#c0392b;border-radius:50%;animation:reports-spin 0.7s linear infinite;flex-shrink:0;"></div>
            <span>Loading reports...</span>
        </div>

        <!-- Content -->
        <div id="reportsModalContent" style="display:none;">
            <div id="assessmentReportsList"></div>
            <div style="height:1px;background:#f3f4f6;"></div>
            <div style="display:flex;flex-direction:row;align-items:center;justify-content:space-between;padding:13px 0;gap:16px;">
                <span style="font-size:14px;color:#1a1a1a;">Student LO Report</span>
                <div id="studentLOReportActions" style="display:flex;flex-direction:row;gap:8px;align-items:center;flex-shrink:0;"></div>
            </div>
        </div>

        <div id="reportsModalError" style="display:none;" class="admin-alert admin-alert-error"></div>
    </div>
</div>

<style>
    @@keyframes reports-spin { to { transform: rotate(360deg); } }
    /* Force correct enrol-tag styles in case of CSS cache */
    a.enrol-tag {
        display: inline-flex !important;
        align-items: center;
        gap: 5px;
        padding: 4px 10px !important;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        margin: 2px 4px 2px 0;
        white-space: nowrap;
        text-decoration: none !important;
        cursor: pointer;
    }
    a.enrol-tag.enrol-tag-current { background: #dbeafe !important; color: #1e40af !important; }
    a.enrol-tag.enrol-tag-past    { background: #f3f4f6 !important; color: #6b7280 !important; }
    a.enrol-tag:hover { filter: brightness(0.92); transform: translateY(-1px); text-decoration: none !important; }
    .report-item-row {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        padding: 13px 0;
        gap: 16px;
    }
    .report-item-divider { height: 1px; background: #f3f4f6; }
    .btn-report-dl {
        display: inline-flex;
        align-items: center;
        background: #c0392b;
        color: #fff !important;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none !important;
        white-space: nowrap;
    }
    .btn-report-dl:hover { background: #a93226; color: #fff !important; text-decoration: none !important; }
    .btn-report-regen {
        display: inline-flex;
        align-items: center;
        background: #fff;
        color: #c0392b !important;
        border: 1.5px solid #c0392b;
        border-radius: 8px;
        padding: 7px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none !important;
        white-space: nowrap;
    }
    .btn-report-regen:hover { background: #fef2f2; text-decoration: none !important; }
</style>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        function toggleAddDept(header) {
            const group = header.closest('.course-dept-group');
            const courses = group.querySelector('.dept-courses');
            group.classList.toggle('collapsed');
            courses.classList.toggle('hidden');
        }

        function toggleEditDept(header) {
            const group = header.closest('.course-dept-group');
            const courses = group.querySelector('.dept-courses');
            group.classList.toggle('collapsed');
            courses.classList.toggle('hidden');
        }

        function filterAddCourses() {
            const yearFilter = document.getElementById('addYearFilter').value;
            const deptFilter = document.getElementById('addDeptFilter').value;
            const searchFilter = document.getElementById('addCourseSearch').value.toLowerCase();

            document.querySelectorAll('#addStudentModal .admin-checkbox-item').forEach(item => {
                const year = item.dataset.year;
                const dept = item.dataset.dept;
                const code = item.dataset.code;
                const title = item.dataset.title;

                const yearMatch = !yearFilter || year === yearFilter;
                const deptMatch = !deptFilter || dept === deptFilter;
                const searchMatch = !searchFilter || code.includes(searchFilter) || title.includes(searchFilter);

                item.classList.toggle('hidden', !(yearMatch && deptMatch && searchMatch));
            });
        }

        function filterEditCourses() {
            const yearFilter = document.getElementById('editYearFilter').value;
            const deptFilter = document.getElementById('editDeptFilter').value;
            const searchFilter = document.getElementById('editCourseSearch').value.toLowerCase();

            document.querySelectorAll('#editStudentCourses .admin-checkbox-item').forEach(item => {
                const year = item.dataset.year;
                const dept = item.dataset.dept;
                const code = item.dataset.code;
                const title = item.dataset.title;

                const yearMatch = !yearFilter || year === yearFilter;
                const deptMatch = !deptFilter || dept === deptFilter;
                const searchMatch = !searchFilter || code.includes(searchFilter) || title.includes(searchFilter);

                item.classList.toggle('hidden', !(yearMatch && deptMatch && searchMatch));
            });
        }

        function openEditStudent(btn) {
            const id = btn.dataset.id;
            const fullName = btn.dataset.name;
            const programme = btn.dataset.programme;
            const status = btn.dataset.status;
            const reason = btn.dataset.reason;
            const courses = btn.dataset.courses ? btn.dataset.courses.split(',').map(Number) : [];

            document.getElementById('editStudentId').value = id;
            document.getElementById('editStudentName').value = fullName;
            document.getElementById('editStudentProgramme').value = programme;
            document.getElementById('editStudentStatus').value = status;
            document.getElementById('editStudentReason').value = reason;

            document.querySelectorAll('#editStudentCourses input[type=checkbox]').forEach(cb => {
                cb.checked = courses.includes(parseInt(cb.value));
            });

            // Reset filters
            document.getElementById('editYearFilter').value = '';
            document.getElementById('editDeptFilter').value = '';
            document.getElementById('editCourseSearch').value = '';
            filterEditCourses();

            openModal('editStudentModal');
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') document.querySelectorAll('.admin-modal-bg.open').forEach(m => m.classList.remove('open'));
        });

        async function openStudentReportsModal(studentInternalId, courseCode, year, trimester, studentName) {
            const modal = document.getElementById('studentReportsModal');
            const loading = document.getElementById('reportsModalLoading');
            const content = document.getElementById('reportsModalContent');
            const errorDiv = document.getElementById('reportsModalError');

            // Reset state
            loading.style.display = 'flex';
            content.style.display = 'none';
            errorDiv.style.display = 'none';
            document.getElementById('reportsModalTitle').textContent = `${studentName} — Reports`;
            document.getElementById('reportsModalSubtitle').textContent = `${courseCode} · ${year} T${trimester}`;

            modal.classList.add('open');

            try {
                const url = `/Admin/GetStudentReports?studentId=${studentInternalId}&courseCode=${encodeURIComponent(courseCode)}&year=${year}&trimester=${trimester}`;
                const res = await fetch(url);
                if (!res.ok) throw new Error('Failed to load report data.');
                const data = await res.json();

                // Render assessment reports
                const list = document.getElementById('assessmentReportsList');
                list.innerHTML = '';

                if (data.assessmentReports && data.assessmentReports.length > 0) {
                    data.assessmentReports.forEach(r => {
                        const row = document.createElement('div');
                        row.className = 'report-item-row';

                        const label = document.createElement('span');
                        label.style.cssText = 'font-size:14px;color:#1a1a1a;flex:1;';
                        label.textContent = `${r.assessmentName} Report`;
                        row.appendChild(label);

                        const actions = document.createElement('div');
                        actions.style.cssText = 'display:flex;flex-direction:row;gap:8px;align-items:center;flex-shrink:0;';

                        if (r.exists && r.downloadUrl) {
                            const btn = document.createElement('a');
                            btn.href = r.downloadUrl;
                            btn.download = r.fileName;
                            btn.className = 'btn-report-dl';
                            btn.textContent = 'Download PDF';
                            actions.appendChild(btn);
                        } else {
                            const span = document.createElement('span');
                            span.style.cssText = 'font-size:13px;color:#9ca3af;font-style:italic;';
                            span.textContent = 'Not yet available';
                            actions.appendChild(span);
                        }

                        row.appendChild(actions);
                        list.appendChild(row);

                        const divider = document.createElement('div');
                        divider.className = 'report-item-divider';
                        list.appendChild(divider);
                    });
                } else {
                    const empty = document.createElement('div');
                    empty.className = 'report-item-row';
                    empty.innerHTML = '<span style="font-size:13px;color:#9ca3af;font-style:italic;">No assessments found for this course.</span>';
                    list.appendChild(empty);
                    const divider = document.createElement('div');
                    divider.className = 'report-item-divider';
                    list.appendChild(divider);
                }

                // Render Student LO Report row
                const loActions = document.getElementById('studentLOReportActions');
                loActions.innerHTML = '';

                if (data.studentLoReport.exists && data.studentLoReport.downloadUrl) {
                    const dlBtn = document.createElement('a');
                    dlBtn.href = data.studentLoReport.downloadUrl;
                    dlBtn.download = data.studentLoReport.fileName;
                    dlBtn.className = 'btn-report-dl';
                    dlBtn.textContent = 'Download PDF';
                    loActions.appendChild(dlBtn);
                }

                if (data.studentLoReport.generateUrl) {
                    const genBtn = document.createElement('a');
                    genBtn.href = data.studentLoReport.generateUrl;
                    genBtn.target = '_blank';
                    genBtn.className = data.studentLoReport.exists ? 'btn-report-regen' : 'btn-report-dl';
                    genBtn.textContent = data.studentLoReport.exists ? 'Re-generate PDF' : 'Generate PDF';
                    loActions.appendChild(genBtn);
                }

                if (!data.studentLoReport.exists && !data.studentLoReport.generateUrl) {
                    loActions.innerHTML = '<span style="font-size:13px;color:#9ca3af;font-style:italic;">Not yet available</span>';
                }

                loading.style.display = 'none';
                content.style.display = 'block';

            } catch (err) {
                loading.style.display = 'none';
                errorDiv.textContent = err.message || 'An error occurred loading reports.';
                errorDiv.style.display = 'block';
            }
        }
    </script>
}