@model List<AIS_LO_System.Models.Student>

@{
    ViewData["Title"] = "Students";
    Layout = "_AdminLayout";
    var courses = ViewBag.Courses as List<AIS_LO_System.Models.Course> ?? new();
}


<div class="admin-content">
    <div class="admin-panel">

        <div class="admin-panel-header">
            <div class="admin-panel-title">Students</div>
            <button class="btn-admin-add" onclick="openModal('addStudentModal')">Add Student</button>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="admin-alert admin-alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="admin-alert admin-alert-error">@TempData["Error"]</div>
        }

        <div class="admin-toolbar">
            <form method="get" class="admin-search-form">
                <input name="search" class="admin-search-input" placeholder="Search by ID or name..."
                       value="@Context.Request.Query["search"]" />
                <select name="courseId" class="admin-filter-select" onchange="this.form.submit()">
                    <option value="">All Courses</option>
                    @foreach (var c in courses)
                    {
                        <option value="@c.Id" selected="@(Context.Request.Query["courseId"] == c.Id.ToString())">
                            @c.Code — @c.Year T@c.Trimester
                        </option>
                    }
                </select>
            </form>

            <div class="admin-status-tabs">
                <a href="?status=all" class="status-tab @(ViewBag.Status == "all" ? "status-tab-active" : "")">All</a>
                <a href="?status=active" class="status-tab @(ViewBag.Status == "active" ? "status-tab-active" : "")">Active</a>
                <a href="?status=inactive" class="status-tab @(ViewBag.Status == "inactive" ? "status-tab-active" : "")">Inactive</a>
            </div>

            <form asp-action="ImportStudents" method="post" enctype="multipart/form-data" style="display:inline">
                @Html.AntiForgeryToken()
                <label class="btn-admin-import">
                    Import CSV
                    <input type="file" name="file" accept=".csv" style="display:none" onchange="this.form.submit()" />
                </label>
            </form>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Student ID</th>
                    <th>Full Name</th>
                    <th>Status</th>
                    <th>Enrolled In</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="admin-empty">No Student Added Yet</td>
                    </tr>
                }
                else
                {
                    @foreach (var s in Model)
                    {
                        bool isActive = s.CourseEnrolments.Any(e => e.Course.Year == ViewBag.CurrentYear);
                        <tr class="@(!isActive ? "row-inactive" : "")">
                            <td>@s.StudentId</td>
                            <td>@s.FullName</td>
                            <td>
                                <span class="status-pill @(isActive ? "status-active" : "status-inactive")">
                                    @(isActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                @foreach (var e in s.CourseEnrolments.OrderByDescending(e => e.Course.Year).ThenBy(e => e.Course.Trimester))
                                {
                                    <a href="@Url.Action("Index", "CourseDashboard", new { courseCode = e.Course.Code, year = e.Course.Year, trimester = e.Course.Trimester })"
                                           class="enrol-tag @(e.Course.Year == ViewBag.CurrentYear ? "enrol-tag-current" : "enrol-tag-past")"
                                           title="View @s.FullName's records in @e.Course.Code">
                                        @e.Course.Code <span class="enrol-tag-year">@(e.Course.Year) T@(e.Course.Trimester)</span>
                                    </a>
                                }
                            </td>
                            <td class="admin-td-actions">
                                <button class="btn-admin-edit"
                                        data-id="@s.Id"
                                        data-name="@s.FullName"
                                        data-courses="@string.Join(",", s.CourseEnrolments.Select(e => e.CourseId))"
                                        onclick="openEditStudent(this)">
                                    Edit
                                </button>
                                <form asp-action="RemoveStudent" method="post" style="display:inline"
                                      onsubmit="return confirm('Remove @s.FullName?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit" class="btn-admin-remove">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Student Modal -->
<div class="admin-modal-bg" id="addStudentModal">
    <div class="admin-modal">
        <div class="admin-modal-title">Add Student</div>
        <form asp-action="AddStudent" method="post">
            @Html.AntiForgeryToken()
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Student ID *</label>
                    <input name="studentId" class="admin-input" placeholder="e.g. 2026006" required />
                </div>
                <div class="admin-form-group">
                    <label>Full Name *</label>
                    <input name="fullName" class="admin-input" placeholder="e.g. Maria Santos" required />
                </div>
            </div>
            <div class="admin-form-group">
                <label>Enrol in Course/s</label>
                
                <!-- Filter Controls -->
                <div class="course-filter-controls">
                    <div class="course-filter-row">
                        <select id="addYearFilter" class="admin-input" onchange="filterAddCourses()">
                            <option value="">All Years</option>
                            @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                        <select id="addDeptFilter" class="admin-input" onchange="filterAddCourses()">
                            <option value="">All Departments</option>
                            @foreach (var dept in courses.Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <option value="@dept">@dept</option>
                            }
                        </select>
                    </div>
                    <input type="text" id="addCourseSearch" class="course-search-input" placeholder="Search course code or title..." onkeyup="filterAddCourses()" />
                </div>

                <!-- Accordion Courses -->
                <div class="course-accordion-wrapper">
                    @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                    {
                        <div class="course-year-group">
                            <div class="course-year-label">@year</div>
                            @foreach (var dept in courses.Where(c => c.Year == year).Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <div class="course-dept-group" data-year="@year" data-dept="@dept">
                                    <div class="course-dept-label" onclick="toggleAddDept(this)">
                                        <span class="dept-toggle">▼</span> @dept
                                    </div>
                                    <div class="dept-courses">
                                        @foreach (var c in courses.Where(c => c.Year == year && c.School == dept).OrderBy(c => c.Trimester).ThenBy(c => c.Code))
                                        {
                                            <label class="admin-checkbox-item" data-year="@c.Year" data-dept="@c.School" data-code="@c.Code" data-title="@c.Title.ToLower()">
                                                <input type="checkbox" name="courseIds" value="@c.Id" />
                                                @c.Code — @c.Title <span class="course-tri-tag">T@(c.Trimester)</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="button" class="btn-admin-cancel" onclick="closeModal('addStudentModal')">Cancel</button>
                <button type="submit" class="btn-admin-save">Add Student</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Student Modal -->
<div class="admin-modal-bg" id="editStudentModal">
    <div class="admin-modal">
        <div class="admin-modal-title">Edit Student</div>
        <form asp-action="EditStudent" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editStudentId" />
            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label>Full Name *</label>
                    <input name="fullName" id="editStudentName" class="admin-input" required />
                </div>
            </div>
            <div class="admin-form-group">
                <label>Enrolled in Course/s</label>
                
                <!-- Filter Controls -->
                <div class="course-filter-controls">
                    <div class="course-filter-row">
                        <select id="editYearFilter" class="admin-input" onchange="filterEditCourses()">
                            <option value="">All Years</option>
                            @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                        <select id="editDeptFilter" class="admin-input" onchange="filterEditCourses()">
                            <option value="">All Departments</option>
                            @foreach (var dept in courses.Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <option value="@dept">@dept</option>
                            }
                        </select>
                    </div>
                    <input type="text" id="editCourseSearch" class="course-search-input" placeholder="Search course code or title..." onkeyup="filterEditCourses()" />
                </div>

                <!-- Accordion Courses -->
                <div class="course-accordion-wrapper" id="editStudentCourses">
                    @foreach (var year in courses.Select(c => c.Year).Distinct().OrderByDescending(y => y))
                    {
                        <div class="course-year-group">
                            <div class="course-year-label">@year</div>
                            @foreach (var dept in courses.Where(c => c.Year == year).Select(c => c.School).Distinct().OrderBy(s => s))
                            {
                                <div class="course-dept-group" data-year="@year" data-dept="@dept">
                                    <div class="course-dept-label" onclick="toggleEditDept(this)">
                                        <span class="dept-toggle">▼</span> @dept
                                    </div>
                                    <div class="dept-courses">
                                        @foreach (var c in courses.Where(c => c.Year == year && c.School == dept).OrderBy(c => c.Trimester).ThenBy(c => c.Code))
                                        {
                                            <label class="admin-checkbox-item" data-year="@c.Year" data-dept="@c.School" data-code="@c.Code" data-title="@c.Title.ToLower()">
                                                <input type="checkbox" name="courseIds" value="@c.Id" />
                                                @c.Code — @c.Title <span class="course-tri-tag">T@(c.Trimester)</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="admin-modal-actions">
                <button type="button" class="btn-admin-cancel" onclick="closeModal('editStudentModal')">Cancel</button>
                <button type="submit" class="btn-admin-save">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        function toggleAddDept(header) {
            const group = header.closest('.course-dept-group');
            const courses = group.querySelector('.dept-courses');
            group.classList.toggle('collapsed');
            courses.classList.toggle('hidden');
        }

        function toggleEditDept(header) {
            const group = header.closest('.course-dept-group');
            const courses = group.querySelector('.dept-courses');
            group.classList.toggle('collapsed');
            courses.classList.toggle('hidden');
        }

        function filterAddCourses() {
            const yearFilter = document.getElementById('addYearFilter').value;
            const deptFilter = document.getElementById('addDeptFilter').value;
            const searchFilter = document.getElementById('addCourseSearch').value.toLowerCase();

            document.querySelectorAll('#addStudentModal .admin-checkbox-item').forEach(item => {
                const year = item.dataset.year;
                const dept = item.dataset.dept;
                const code = item.dataset.code;
                const title = item.dataset.title;

                const yearMatch = !yearFilter || year === yearFilter;
                const deptMatch = !deptFilter || dept === deptFilter;
                const searchMatch = !searchFilter || code.includes(searchFilter) || title.includes(searchFilter);

                item.classList.toggle('hidden', !(yearMatch && deptMatch && searchMatch));
            });
        }

        function filterEditCourses() {
            const yearFilter = document.getElementById('editYearFilter').value;
            const deptFilter = document.getElementById('editDeptFilter').value;
            const searchFilter = document.getElementById('editCourseSearch').value.toLowerCase();

            document.querySelectorAll('#editStudentCourses .admin-checkbox-item').forEach(item => {
                const year = item.dataset.year;
                const dept = item.dataset.dept;
                const code = item.dataset.code;
                const title = item.dataset.title;

                const yearMatch = !yearFilter || year === yearFilter;
                const deptMatch = !deptFilter || dept === deptFilter;
                const searchMatch = !searchFilter || code.includes(searchFilter) || title.includes(searchFilter);

                item.classList.toggle('hidden', !(yearMatch && deptMatch && searchMatch));
            });
        }

        function openEditStudent(btn) {
            const id = btn.dataset.id;
            const fullName = btn.dataset.name;
            const courses = btn.dataset.courses ? btn.dataset.courses.split(',').map(Number) : [];

            document.getElementById('editStudentId').value = id;
            document.getElementById('editStudentName').value = fullName;

            document.querySelectorAll('#editStudentCourses input[type=checkbox]').forEach(cb => {
                cb.checked = courses.includes(parseInt(cb.value));
            });

            // Reset filters
            document.getElementById('editYearFilter').value = '';
            document.getElementById('editDeptFilter').value = '';
            document.getElementById('editCourseSearch').value = '';
            filterEditCourses();

            openModal('editStudentModal');
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') document.querySelectorAll('.admin-modal-bg.open').forEach(m => m.classList.remove('open'));
        });
    </script>
}