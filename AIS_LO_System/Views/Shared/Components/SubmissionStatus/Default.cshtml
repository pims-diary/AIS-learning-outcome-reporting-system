@model AIS_LO_System.Models.CourseSubmission?
@using AIS_LO_System.Models

@if (Model != null && (Model.Status == SubmissionStatus.Approved || Model.Status == SubmissionStatus.Denied))
{
    var isApproved = Model.Status == SubmissionStatus.Approved;
    var icon = isApproved ? "✅" : "❌";
    var statusText = isApproved ? "Approved" : "Denied";
    var accentColor = isApproved ? "#198754" : "#dc3545";
    var bgColor = isApproved ? "#f0fdf4" : "#fff5f5";
    var pillBg = isApproved ? "#d1fae5" : "#fee2e2";
    var pillColor = isApproved ? "#065f46" : "#991b1b";
    var storageKey = $"sub_seen_{Model.Id}_{Model.Status}_{Model.ReviewedAt?.Ticks}";

    <!-- Small persistent indicator (always visible after popup dismissed) -->
    <div id="subStatusBadge" style="display:none; margin-bottom:16px;">
        <span style="
            display:inline-flex; align-items:center; gap:6px;
            padding:5px 12px; border-radius:20px;
            background:@pillBg; color:@pillColor;
            font-size:13px; font-weight:600;">
            @icon @statusText
            @if (!string.IsNullOrWhiteSpace(Model.ModeratorComment))
            {
                <span style="font-weight:400;">— @Model.ModeratorComment</span>
            }
        </span>
    </div>

    <!-- Instagram-style popup overlay -->
    <div id="subStatusOverlay" style="
        display:none; position:fixed; inset:0; z-index:9999;
        background:rgba(0,0,0,0.55); backdrop-filter:blur(2px);
        align-items:center; justify-content:center;">

        <div style="
            background:#fff; border-radius:16px;
            box-shadow:0 12px 48px rgba(0,0,0,0.22);
            width:100%; max-width:400px; margin:0 16px;
            overflow:hidden; animation:popIn 0.2s ease;
            border-top:4px solid @accentColor;">

            <!-- Icon + title -->
            <div style="padding:28px 24px 20px; text-align:center;">
                <div style="
                    width:60px; height:60px; border-radius:50%;
                    background:@bgColor; display:inline-flex;
                    align-items:center; justify-content:center;
                    font-size:28px; margin-bottom:14px;">
                    @icon
                </div>
                <div style="font-size:18px; font-weight:700; color:#111; margin-bottom:6px;">
                    Submission @statusText
                </div>
                <div style="font-size:13px; color:#888;">
                    @Model.ItemLabel
                </div>
            </div>

            <!-- Detail row -->
            <div style="
                background:@bgColor; margin:0 20px 20px;
                border-radius:10px; padding:14px 16px;">
                @if (!string.IsNullOrWhiteSpace(Model.ModeratorComment))
                {
                    <div style="font-size:13px; color:#444; margin-bottom:6px;">
                        <strong>Comment:</strong> @Model.ModeratorComment
                    </div>
                }
                @if (Model.ReviewedAt.HasValue)
                {
                    <div style="font-size:12px; color:#999;">
                        Reviewed @Model.ReviewedAt.Value.ToString("dd MMM yyyy, h:mm tt")
                    </div>
                }
            </div>

            <!-- Buttons -->
            <div style="border-top:1px solid #f0f0f0;">
                <button onclick="dismissSubStatus()" style="
                    display:block; width:100%; padding:15px;
                    background:none; border:none; cursor:pointer;
                    font-size:14px; font-weight:700; color:#1a6fbb;">
                    OK
                </button>
            </div>
        </div>
    </div>

    <style>
        @@keyframes popIn {
            from { transform:scale(0.9); opacity:0; }
            to   { transform:scale(1);   opacity:1; }
        }
    </style>

    <script>
        (function() {
            const key = '@storageKey';
            const overlay = document.getElementById('subStatusOverlay');
            const badge   = document.getElementById('subStatusBadge');

            if (!localStorage.getItem(key)) {
                overlay.style.display = 'flex';
            } else {
                badge.style.display = 'block';
            }
        })();

        function dismissSubStatus() {
            document.getElementById('subStatusOverlay').style.display = 'none';
            document.getElementById('subStatusBadge').style.display = 'block';
            localStorage.setItem('@storageKey', '1');
        }
    </script>
}
else if (Model != null && Model.Status == SubmissionStatus.Pending)
{
    var pendingMessage = (Model.ItemType == SubmissionItemType.LearningOutcomes || Model.ItemType == SubmissionItemType.Assessments)
        ? "Changes are waiting for moderator approval. Live course data stays unchanged until approval."
        : $"Submitted {Model.SubmittedAt:dd MMM yyyy, h:mm tt}";

    <!-- Pending just shows a quiet inline banner, no popup needed -->
    <div class="sub-status-banner sub-status-pending">
        <span class="sub-status-icon">⏳</span>
        <div class="sub-status-body">
            <strong>Pending</strong>
            <span class="sub-status-date">@pendingMessage</span>
        </div>
    </div>
}
