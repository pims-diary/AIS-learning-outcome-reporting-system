@model LOARS.Web.Models.Dashboard.LecturerDashboardViewModel
@using AIS_LO_System.Models
@{
    Layout = null;
}

<aside id="sidebar" class="dash-sidebar">

    <div class="sidebar-header">
        <span class="sidebar-title">Home</span>
        <button class="sidebar-close" onclick="toggleSidebar()">✕</button>
    </div>

    @if (Model.IsModeratorOfAnyCourse)
    {
        <div class="sidebar-mod-section">
            <a asp-controller="Moderator" asp-action="Inbox" class="sidebar-mod-link">
                <span class="sidebar-mod-icon">📋</span>
                Moderator Inbox
            </a>
        </div>
    }

    @foreach (var year in Model.Years.OrderByDescending(y => y))
    {
        <div class="year-block">
            <div class="year-title">
                @year
            </div>

            <div class="trimester-links">
                @foreach (var tri in Model.TrimestersByYear[year])
                {
                    var isActive =
                    Model.SelectedYear == year &&
                    Model.SelectedTrimester == tri;

                    <a asp-controller="LecturerDashboard"
                           asp-action="Index"
                           asp-route-year="@year"
                           asp-route-trimester="@tri"
                           class="tri-link @(isActive ? "active" : "")">

                        Trimester @tri
                    </a>
                }
            </div>
        </div>
    }
</aside>