@model dynamic
@{
    Layout = null;
    var _fullName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "User";
    var _initials = string.Concat(_fullName.Split(' ').Take(2).Select(w => w[0])).ToUpper();
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/moderator.css" />
    <link rel="stylesheet" href="~/css/page-header.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<body>

    <div class="dash-shell">

        <!-- Sidebar -->
        @await Component.InvokeAsync("Sidebar", new
        {
            year = ViewBag.Year,
            trimester = ViewBag.Trimester
        })

        <!-- Main -->
        <main class="dash-main">

            <!-- Topbar -->
            <div class="dash-topbar">

                <!-- LEFT -->
                <button class="hamburger" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>

                <!-- CENTER LOGO -->
                <div class="brand">
                    <img src="~/images/AIS_logo.png" class="brand-logo" />
                </div>

                <!-- RIGHT -->
                <div class="topbar-right">

                    <!-- FIX #4: Functional notification bell via ViewComponent -->
                    @await Component.InvokeAsync("Notification")

                    <div class="divider"></div>

                    <div class="user-wrapper" onclick="toggleUserMenu()">
                        <div class="user-circle">@_initials</div>
                        <i class="bi bi-chevron-down user-arrow"></i>

                        <div id="userDropdown" class="user-dropdown">

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post"
                                  class="logout-form">

                                <button type="submit" class="dropdown-item">
                                    <i class="bi bi-box-arrow-right"></i>
                                    Logout
                                </button>
                            </form>

                        </div>
                    </div>

                </div>
            </div>

            <div class="dash-content">
                @{
                    var impersonatedBy = User.FindFirst("ImpersonatedBy")?.Value;
                    var impersonatedName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value;
                }
                @if (!string.IsNullOrEmpty(impersonatedBy))
                {
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:16px;
                        background:linear-gradient(135deg,#fff3cd 0%,#ffeaa0 100%);
                        border:1.5px solid #e6c200; border-radius:12px;
                        padding:14px 20px; margin-bottom:32px;
                        font-size:13.5px; color:#5a3e00;
                        box-shadow:0 2px 8px rgba(230,194,0,0.15);">
                        <div style="display:flex; align-items:center; gap:10px; line-height:1.4;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#5a3e00" viewBox="0 0 16 16" style="flex-shrink:0; opacity:0.75;">
                                <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 3a.75.75 0 1 1 0 1.5A.75.75 0 0 1 8 4zm0 3c.414 0 .75.336.75.75v3.5a.75.75 0 0 1-1.5 0v-3.5C7.25 7.336 7.586 7 8 7z" />
                            </svg>
                            <span>Viewing as <strong>@impersonatedName</strong> &mdash; read-only, no changes will be saved.</span>
                        </div>
                        <form asp-controller="Account" asp-action="StopImpersonating" method="post" style="margin:0; flex-shrink:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    style="background:#c21c00; color:#fff; border:none; border-radius:20px;
                                padding:10px 20px; font-size:13.5px; font-weight:600;
                                cursor:pointer; white-space:nowrap; font-family:inherit;">
                                Return to Admin
                            </button>
                        </form>
                    </div>
                }
                @RenderBody()
            </div>

        </main>

    </div>

    <script>
            function toggleSidebar() {
                document.getElementById('sidebar').classList.toggle('open');
            }

            function toggleYear(year) {
                document.getElementById('year-' + year)
                    .classList.toggle('open');
            }

            function toggleUserMenu() {
                event.stopPropagation();
                // Close notification dropdown if open
                document.getElementById('notifDropdown')?.classList.remove('open');
                document.getElementById("userDropdown")
                    .classList.toggle("open");
            }

            // Close all dropdowns when clicking outside
            document.addEventListener("click", function () {
                document.getElementById("userDropdown")
                    .classList.remove("open");
                // notifDropdown close is handled inside the component's own script
            });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
