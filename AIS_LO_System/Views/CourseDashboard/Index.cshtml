@{
    ViewData["Title"] = "Course Dashboard";
    Layout = "_DashboardLayout";
}

<link rel="stylesheet" href="~/css/course.css" />
<script src="~/js/course.js" defer></script>

<div class="course-container">

    <!-- Dynamic title -->
    <h2 class="course-title">
        @ViewBag.CourseCode @ViewBag.CourseTitle
    </h2>

    <!-- Dynamic course date range -->
    <p class="course-date">
        @ViewBag.DateRange
    </p>

    <!-- Back button  -->
    <div style="margin-bottom: 20px;">
        <a class="btn btn-outline-secondary"
           asp-controller="LecturerDashboard"
           asp-action="Index"
           asp-route-year="@ViewBag.Year"
           asp-route-trimester="@ViewBag.Trimester">
            Back to Dashboard
        </a>
    </div>

    @if (ViewBag.AssessmentTotalWarning != null)
    {
        <div style="background:#fff3cd; border:1px solid #ffc107; color:#856404; padding:12px 16px; border-radius:8px; margin-bottom:20px;">
            @ViewBag.AssessmentTotalWarning
        </div>
    }

    <!-- Expand / Collapse -->
    <div class="expand-toggle">
        <button id="toggleAll">Expand all</button>
    </div>

    <!-- Course Information -->
    <div class="accordion">
        <div class="accordion-header">
            <div class="header-left">
                <div class="icon-circle">
                    <span class="icon-arrow">›</span>
                </div>
                <span class="accordion-title">Course Information</span>
            </div>
        </div>

        <div class="accordion-body">
            <a asp-controller="CourseInformation" asp-action="Outline"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester">
                Course Outline
            </a>

            <a asp-controller="CourseInformation" asp-action="LearningOutcomes"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester">
                Learning Outcomes
            </a>

            <a asp-controller="CourseInformation" asp-action="Assessments"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester">
                Assessments
            </a>

        </div>

    </div>

    <!-- Assessments -->
    <div class="accordion">
        <div class="accordion-header">
            <div class="header-left">
                <div class="icon-circle">
                    <span class="icon-arrow">›</span>
                </div>
                <span class="accordion-title">Assessments</span>
            </div>
        </div>

        <div class="accordion-body">
            @{
                var assessments = ViewBag.Assessments as List<AIS_LO_System.Models.Assignment>
                ?? new List<AIS_LO_System.Models.Assignment>();
            }

            @if (assessments.Any())
            {
                @foreach (var assess in assessments)
                {
                    <a asp-controller="Assignment"
                       asp-action="Index"
                       asp-route-assessmentName="@assess.AssessmentName"
                       asp-route-courseCode="@ViewBag.CourseCode"
                       asp-route-courseTitle="@ViewBag.CourseTitle"
                       asp-route-year="@ViewBag.Year"
                       asp-route-trimester="@ViewBag.Trimester">
                        @assess.AssessmentName
                        @if (assess.MarksPercentage > 0)
                        {
                            <span style="color:#888; font-size:0.85em;">(@assess.MarksPercentage%)</span>
                        }
                    </a>
                }
            }
            else
            {
                <a asp-controller="Assignment"
                   asp-action="Index"
                   asp-route-assessmentName="Assignment 1"
                   asp-route-courseCode="@ViewBag.CourseCode"
                   asp-route-courseTitle="@ViewBag.CourseTitle"
                   asp-route-year="@ViewBag.Year"
                   asp-route-trimester="@ViewBag.Trimester">
                    Assignment 1
                </a>

                <a asp-controller="Assignment"
                   asp-action="Index"
                   asp-route-assessmentName="Assignment 2"
                   asp-route-courseCode="@ViewBag.CourseCode"
                   asp-route-courseTitle="@ViewBag.CourseTitle"
                   asp-route-year="@ViewBag.Year"
                   asp-route-trimester="@ViewBag.Trimester">
                    Assignment 2
                </a>

                <a asp-controller="Assignment"
                   asp-action="Index"
                   asp-route-assessmentName="Midterm"
                   asp-route-courseCode="@ViewBag.CourseCode"
                   asp-route-courseTitle="@ViewBag.CourseTitle"
                   asp-route-year="@ViewBag.Year"
                   asp-route-trimester="@ViewBag.Trimester">
                    Midterm
                </a>
            }
        </div>
    </div>

    <!-- Reports -->
    <div class="accordion">
        <div class="accordion-header">
            <div class="header-left">
                <div class="icon-circle">
                    <span class="icon-arrow">›</span>
                </div>
                <span class="accordion-title">Reports</span>
            </div>
        </div>

        <div class="accordion-body">
            <a asp-controller="StudentLOReport"
               asp-action="Index"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-courseTitle="@ViewBag.CourseTitle"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester">
                Student LO Report
            </a>

            <a asp-controller="CourseLOReport"
               asp-action="Index"
               asp-route-courseCode="@ViewBag.CourseCode"
               asp-route-courseTitle="@ViewBag.CourseTitle"
               asp-route-year="@ViewBag.Year"
               asp-route-trimester="@ViewBag.Trimester">
                Course LO Report
            </a>
        </div>
    </div>

</div>
